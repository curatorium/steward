source ./steward;
STEWARD="${STEWARD:-$SRC_DIR/steward}";

# Helper: reset /tmp/steward between tests
reset() {
	rm -fR /tmp/steward;
	mkdir -p /tmp/steward;
}

# Helper: check if pattern exists in any file under /tmp/steward
generated() {
	grep -rq -- "$1" /tmp/steward 2>/dev/null;
}

# Helper: logging stand-in for an external tool, at an explicit path. A real
# executable, because apply stages reach tools through xargs and absolute paths.
fake:at() {
	local path="$1" name="$2" body="${3:-}";
	mkdir -p "${path%/*}";
	printf '#!/bin/bash\necho "%s $* @$PWD" >> "%s"\n%s\n' "$name" "$TEST_DIR/cmd.log" "$body" > "$path";
	chmod +x "$path";
}

# Helper: put a logging stand-in for an external tool first on PATH
fake() {
	fake:at "$TEST_DIR/bin/$1" "$1" "${2:-}";
	PATH="$TEST_DIR/bin:$PATH";
}

# Helper: assert a recorded invocation of a faked tool
logged() {
	grep -qF -- "$1" "$TEST_DIR/cmd.log" 2>/dev/null;
}


# steward:key Tests
#------------------------------------------------------------------------------

test:key:valid() {
	reset;
	steward:key docker https://download.docker.com/linux/ubuntu/gpg || return 1;
	[[ -f /tmp/steward/key.lst ]] || return 1;
	grep -qP "^docker\thttps://download.docker.com" /tmp/steward/key.lst || return 1;
}

test:key:missing-name() {
	reset;
	local ARGS=();
	steward:key 2>/dev/null && return 1;
	return 0;
}

test:key:missing-url() {
	reset;
	local ARGS=(docker);
	steward:key docker 2>/dev/null && return 1;
	return 0;
}

test:key:non-http-url() {
	reset;
	steward:key docker ftp://example.com/key.gpg 2>/dev/null && return 1;
	[[ ! -f /tmp/steward/key.lst ]] || return 1;
}

# steward:src Tests
#------------------------------------------------------------------------------

test:src:valid-full() {
	reset;
	steward:src docker https://download.docker.com/linux/ubuntu jammy stable || return 1;
	[[ -f /tmp/steward/src.lst ]] || return 1;
	grep -q "download.docker.com" /tmp/steward/src.lst || return 1;
	grep -q "jammy" /tmp/steward/src.lst || return 1;
	grep -q "stable" /tmp/steward/src.lst || return 1;
}

test:src:valid-deb-url() {
	reset;
	steward:src https://example.com/package.deb || return 1;
	[[ -f /tmp/steward/src.lst ]] || return 1;
	grep -q "example.com/package.deb" /tmp/steward/src.lst || return 1;
}

test:src:no-key-flag() {
	reset;
	steward:src --no-key ppa https://ppa.example.com jammy main || return 1;
	generated "signed-by" && return 1;
	return 0;
}

test:src:minimal-repo() {
	reset;
	steward:src myrepo https://repo.example.com || return 1;
	grep -q "repo.example.com" /tmp/steward/src.lst || return 1;
	grep -q "signed-by" /tmp/steward/src.lst || return 1;
}

test:src:missing-name() {
	reset;
	steward:src 2>/dev/null && return 1;
	return 0;
}

test:src:multiple-components() {
	reset;
	steward:src myrepo https://repo.example.com jammy main universe restricted || return 1;
	grep -qP "\tjammy\tmain universe restricted$" /tmp/steward/src.lst || return 1;
}

test:src:signed-by-names-the-keyring() {
	reset;
	steward:src docker https://download.docker.com/linux/ubuntu jammy stable || return 1;
	grep -qF "[signed-by=/usr/share/keyrings/docker.gpg]" /tmp/steward/src.lst || return 1;
}

# steward:apt Tests
#------------------------------------------------------------------------------

test:apt:valid() {
	reset;
	steward:apt vim || return 1;
	grep -q "^vim$" /tmp/steward/apt.pkgs || return 1;
}

test:apt:versioned() {
	reset;
	steward:apt "vim=2:8.2.3995-1" || return 1;
	grep -q "vim=2:8.2.3995-1" /tmp/steward/apt.pkgs || return 1;
}

test:apt:try-flag() {
	reset;
	steward:apt --try optional-pkg || return 1;
	grep -q "optional-pkg" /tmp/steward/apt-try.pkgs || return 1;
}

test:apt:temp-flag() {
	reset;
	steward:apt --temp build-dep || return 1;
	grep -q "build-dep" /tmp/steward/apt-temp.pkgs || return 1;
	# must not also read as an explicit request, or clean-up can never subtract it away
	grep -q "build-dep" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:apt:try-temp-combo() {
	reset;
	steward:apt --try --temp optional-build-dep || return 1;
	grep -q "optional-build-dep" /tmp/steward/apt-temp-try.pkgs || return 1;
	grep -q "optional-build-dep" /tmp/steward/apt-try.pkgs 2>/dev/null && return 1;
	return 0;
}

test:apt:temp-explicit-override() {
	reset;
	steward:apt --temp build-dep || return 1;
	steward:apt build-dep || return 1;
	# recorded as both temporary and explicit; apply:clean-up is what subtracts the two
	grep -q "build-dep" /tmp/steward/apt-temp.pkgs || return 1;
	grep -q "build-dep" /tmp/steward/apt.pkgs || return 1;
}

test:apt:missing-name() {
	reset;
	steward:apt 2>/dev/null && return 1;
	return 0;
}

# steward:deb Tests
#------------------------------------------------------------------------------

test:deb:valid() {
	reset;
	steward:deb https://example.com/package.deb || return 1;
	[[ -f /tmp/steward/deb.pkgs ]] || return 1;
	grep -q "example.com" /tmp/steward/deb.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt.pkgs || return 1;
}

test:deb:try-flag() {
	reset;
	steward:deb --try https://example.com/package.deb || return 1;
	grep -q "example.com" /tmp/steward/deb.pkgs || return 1;
	grep -qP "\ttrue$" /tmp/steward/deb.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt-try.pkgs || return 1;
}

test:deb:temp-flag() {
	reset;
	steward:deb --temp https://example.com/package.deb || return 1;
	grep -q "example.com" /tmp/steward/deb.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt-temp.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:deb:try-temp-combo() {
	reset;
	steward:deb --try --temp https://example.com/package.deb || return 1;
	grep -qP "\ttrue$" /tmp/steward/deb.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt-temp-try.pkgs || return 1;
	grep -q "/var/cache/steward/" /tmp/steward/apt-try.pkgs 2>/dev/null && return 1;
	return 0;
}

test:deb:missing-url() {
	reset;
	steward:deb 2>/dev/null && return 1;
	return 0;
}

test:deb:invalid-url() {
	reset;
	steward:deb /local/path.deb 2>/dev/null && return 1;
	return 0;
}

test:deb:url-slugified-into-filename() {
	reset;
	steward:deb "https://example.com/pool/main/pkg_1.0~beta+1_amd64.deb" || return 1;
	grep -qP "\thttps-example.com-pool-main-pkg_1.0-beta-1_amd64.deb\t" /tmp/steward/deb.pkgs || return 1;
	grep -qF "/var/cache/steward/https-example.com-pool-main-pkg_1.0-beta-1_amd64.deb" /tmp/steward/apt.pkgs || return 1;
}

