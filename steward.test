	grep -qP "^/app\tflask requests$" /tmp/steward/pip.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/pip.pkgs) -eq 1 ]] || return 1;
}

test:pip:missing-name() {
	reset;
	steward:pip 2>/dev/null && return 1;
	return 0;
}

# steward:go Tests
