	[[ $(wc -l < /tmp/steward/go.pkgs) -eq 1 ]] || return 1;
}

test:go:missing-name() {
	reset;
	steward:go 2>/dev/null && return 1;
	return 0;
}

# steward::apply chown Tests

# chown logs to a file, not a variable: the stubs are scoped to a subshell
# shellcheck disable=SC2329
chown:stub() {
	chown() { echo "CHOWN $*" >> /tmp/steward/chown.log; };
	npm()      { [[ "$1" == "config" ]] && echo /tmp/steward/fake; return 0; };
	pip3()     { [[ "$1" == "cache"  ]] && echo /tmp/steward/fake; return 0; };
	go()       { [[ "$1" == "env"    ]] && echo /tmp/steward/fake; return 0; };
	composer() { [[ "$1" == "config" ]] && echo /tmp/steward/fake; return 0; };
}

test:chown:npm:without-sudo-user() {
	reset; printf '!global\tyarn\n' > /tmp/steward/npm.pkgs;
	( chown:stub; unset SUDO_USER; steward::apply:npm; ) || return 1;
}

test:chown:npm:with-sudo-user() {
	reset; printf '!global\tyarn\n' > /tmp/steward/npm.pkgs;
	( chown:stub; SUDO_USER=someone; steward::apply:npm; ) || return 1;
	grep -q "^CHOWN -R someone /tmp/steward/fake$" /tmp/steward/chown.log || return 1;
}

test:chown:pip:without-sudo-user() {
	reset; printf '!global\tflask\n' > /tmp/steward/pip.pkgs;
	( chown:stub; unset SUDO_USER; steward::apply:pip; ) || return 1;
}

test:chown:pip:with-sudo-user() {
	reset; printf '!global\tflask\n' > /tmp/steward/pip.pkgs;
	( chown:stub; SUDO_USER=someone; steward::apply:pip; ) || return 1;
	grep -q "^CHOWN -R someone /tmp/steward/fake$" /tmp/steward/chown.log || return 1;
}

test:chown:go:without-sudo-user() {
	reset; printf '!global\tgithub.com/some/pkg@latest\n' > /tmp/steward/go.pkgs;
	( chown:stub; unset SUDO_USER; steward::apply:go; ) || return 1;
}

test:chown:go:with-sudo-user() {
	reset; printf '!global\tgithub.com/some/pkg@latest\n' > /tmp/steward/go.pkgs;
	( chown:stub; SUDO_USER=someone; steward::apply:go; ) || return 1;
	grep -q "^CHOWN -R someone /tmp/steward/fake /tmp/steward/fake$" /tmp/steward/chown.log || return 1;
}

test:chown:composer:without-sudo-user() {
	reset; printf '!global\tlaravel/installer\n' > /tmp/steward/composer.pkgs;
	( chown:stub; unset SUDO_USER; steward::apply:composer; ) || return 1;
}

test:chown:composer:with-sudo-user() {
	reset; printf '!global\tlaravel/installer\n' > /tmp/steward/composer.pkgs;
	# shellcheck disable=SC2034
	( chown:stub; SUDO_USER=someone; steward::apply:composer; ) || return 1;
	grep -q "^CHOWN -R someone /tmp/steward/fake /tmp/steward/fake$" /tmp/steward/chown.log || return 1;
}

# steward:eager Tests
#------------------------------------------------------------------------------

test:eager:valid() {
	reset;
	steward:eager setup <<<"echo hello";
	generated "echo hello" || return 1;
	[[ -f /tmp/steward/eager-00-setup.sh ]] || return 1;
}

test:eager:custom-order() {
	reset;
	steward:eager :50 early <<<"echo first";
	[[ -f /tmp/steward/eager-50-early.sh ]] || return 1;
}

test:eager:base-range() {
	reset;
	steward:eager :99 max <<<"echo ceiling";
	[[ -f /tmp/steward/eager-99-max.sh ]] || return 1;
}

test:eager:no-name() {
	reset;
	steward:eager <<<"echo anonymous" || return 1;
	[[ -f /tmp/steward/eager-00.sh ]] || return 1;
}

test:eager:ord-without-name() {
	reset;
	steward:eager :50 <<<"echo ordonly" || return 1;
	[[ -f /tmp/steward/eager-50.sh ]] || return 1;
}

test:eager:same-label-appends() {
	reset;
	steward:eager setup <<<"echo one" || return 1;
	steward:eager setup <<<"echo two" || return 1;
