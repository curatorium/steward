# steward:include Tests
#------------------------------------------------------------------------------

test:include:local-file() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt included-pkg' > "$tmpfile";
	steward:include "$tmpfile" || return 1;
	rm -f "$tmpfile";
	grep -q "included-pkg" /tmp/steward/apt.pkgs || return 1;
}

test:include:missing-file() {
	reset;
	steward:include /nonexistent/file 2>/dev/null && return 1;
	return 0;
}

test:include:nested() {
	reset;
	echo 'steward:apt inner-pkg' > "$TEST_DIR/inner";
	echo "steward:include $TEST_DIR/inner" > "$TEST_DIR/outer";
	echo 'steward:apt outer-pkg' >> "$TEST_DIR/outer";
	steward:include "$TEST_DIR/outer" || return 1;
	grep -q "inner-pkg" /tmp/steward/apt.pkgs || return 1;
	grep -q "outer-pkg" /tmp/steward/apt.pkgs || return 1;
}

test:include:relative-path() {
	reset;
	echo 'steward:apt relative-pkg' > "$TEST_DIR/relative.Stewardfile";
	steward:include ./relative.Stewardfile || return 1;
	grep -q "relative-pkg" /tmp/steward/apt.pkgs || return 1;
}

# steward:guard Tests
#------------------------------------------------------------------------------

test:guard:cmd-present() {
	reset;
	# guard should exit 0 (skip) when command exists; run in subshell to catch exit
	(steward:guard bash) && return 0;
	return 1;
}

test:guard:cmd-absent() {
	reset;
	# guard should NOT exit when command doesn't exist; function continues
	(steward:guard nonexistent-cmd-xyz-12345 && echo "continued") || return 1;
	return 0;
}

test:guard:file-present() {
	reset;
	local tmpfile=$(mktemp);
	(steward:guard --file "$tmpfile") && { rm -f "$tmpfile"; return 0; };
	rm -f "$tmpfile";
	return 1;
}

test:guard:file-absent() {
	reset;
	(steward:guard --file /nonexistent/file/xyz && echo "continued") || return 1;
	return 0;
}

test:guard:dir-present() {
	reset;
	(steward:guard --dir /tmp) && return 0;
	return 1;
}

test:guard:dir-absent() {
	reset;
	(steward:guard --dir /nonexistent/dir/xyz && echo "continued") || return 1;
	return 0;
}

test:guard:pkg-present() {
	reset;
	# bash is dpkg-managed on every test box that has bash itself.
	(steward:guard --pkg bash) && return 0;
	return 1;
}

test:guard:pkg-absent() {
	reset;
	(steward:guard --pkg nonexistent-pkg-xyz-12345 && echo "continued") || return 1;
	return 0;
}

test:guard:cmd-success() {
	reset;
	(steward:guard --cmd 'true') && return 0;
	return 1;
}

test:guard:cmd-failure() {
	reset;
	(steward:guard --cmd 'false' && echo "continued") || return 1;
	return 0;
}

test:guard:cmd-multi-word() {
	reset;
	# Whole quoted string is one positional arg; bash -c runs it.
	(steward:guard --cmd 'test -d /tmp && test -r /tmp') && return 0;
	return 1;
}

test:guard:force-bypasses-file() {
	reset;
	touch "$TEST_DIR/present";
	local out; out=$( force=true; steward:guard --file "$TEST_DIR/present" && echo CONTINUED );
	[[ "$out" == "CONTINUED" ]] || return 1;
}

test:guard:force-bypasses-dir() {
	reset;
	local out; out=$( force=true; steward:guard --dir /tmp && echo CONTINUED );
	[[ "$out" == "CONTINUED" ]] || return 1;
}

test:guard:force-bypasses-pkg() {
	reset;
	local out; out=$( force=true; steward:guard --pkg bash && echo CONTINUED );
	[[ "$out" == "CONTINUED" ]] || return 1;
}

test:guard:force-bypasses-cmd() {
	reset;
	local out; out=$( force=true; steward:guard --cmd 'true' && echo CONTINUED );
	[[ "$out" == "CONTINUED" ]] || return 1;
}

test:guard:second-guard-still-evaluated() {
	reset;
	local out; out=$( steward:guard nonexistent-cmd-xyz-12345; steward:guard --cmd 'false'; echo CONTINUED );
	[[ "$out" == "CONTINUED" ]] || return 1;
}

test:guard:does-not-affect-other-functions() {
	reset;
	# Define two functions: first one guards (skips), second should still run
	local tmpdir=$(mktemp -d);
	cat > "$tmpdir/Stewardfile" <<'STEW'
guarded_func() {
	guard bash;
	apt should-not-be-installed;
}
unguarded_func() {
	apt should-be-installed;
}
STEW
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmpdir/Stewardfile") >/dev/null 2>&1 || { rm -fR "$tmpdir"; return 1; };
	rm -fR "$tmpdir";
	grep -q "should-not-be-installed" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	grep -q "should-be-installed" /tmp/steward/apt.pkgs || return 1;
	return 0;
}

test:guard:force-skips-guard() {
	reset;
	# --force should bypass guards: guarded task should run even though bash exists
	local tmpdir=$(mktemp -d);
	cat > "$tmpdir/Stewardfile" <<'STEW'
guarded_func() {
	guard bash;
	apt guarded-pkg;
}
STEW
	(cd "$SRC_DIR" && "$STEWARD" --dry-run --force "$tmpdir/Stewardfile") >/dev/null 2>&1 || { rm -fR "$tmpdir"; return 1; };
	rm -fR "$tmpdir";
	grep -q "guarded-pkg" /tmp/steward/apt.pkgs || return 1;
}

# Command Interface Tests (using --dry-run to avoid sudo)
#------------------------------------------------------------------------------

test:cli:file-args() {
	reset;
	local tmp1=$(mktemp) tmp2=$(mktemp);
	echo 'steward:apt pkg-from-file1' > "$tmp1";
	echo 'steward:apt pkg-from-file2' > "$tmp2";
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmp1" "$tmp2") >/dev/null 2>&1 || return 1;
	rm -f "$tmp1" "$tmp2";
	grep -q "pkg-from-file1" /tmp/steward/apt.pkgs || return 1;
	grep -q "pkg-from-file2" /tmp/steward/apt.pkgs || return 1;
}

test:cli:pipe-cat() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt pkg-from-pipe' > "$tmpfile";
	cat "$tmpfile" | (cd "$SRC_DIR" && "$STEWARD" --dry-run) >/dev/null 2>&1 || return 1;
	rm -f "$tmpfile";
	grep -q "pkg-from-pipe" /tmp/steward/apt.pkgs || return 1;
}

test:cli:redirect-file() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt pkg-from-redirect' > "$tmpfile";
	(cd "$SRC_DIR" && "$STEWARD" --dry-run < "$tmpfile") >/dev/null 2>&1 || return 1;
	rm -f "$tmpfile";
	grep -q "pkg-from-redirect" /tmp/steward/apt.pkgs || return 1;
}

test:cli:herestring() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run <<<"steward:apt pkg-from-herestring") >/dev/null 2>&1 || return 1;
	grep -q "pkg-from-herestring" /tmp/steward/apt.pkgs || return 1;
}

test:cli:process-substitution() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run < <(echo "steward:apt pkg-from-procsub")) >/dev/null 2>&1 || return 1;
	grep -q "pkg-from-procsub" /tmp/steward/apt.pkgs || return 1;
}

test:cli:heredoc() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run <<STEW) >/dev/null 2>&1 || return 1;
steward:apt pkg-from-heredoc
STEW
	grep -q "pkg-from-heredoc" /tmp/steward/apt.pkgs || return 1;
}

test:cli:default-stewardfile() {
	reset;
	local tmpdir=$(mktemp -d);
	echo 'steward:apt pkg-from-default' > "$tmpdir/Stewardfile";
	ln -s "$SRC_DIR/.deps" "$tmpdir/.deps";
	(cd "$tmpdir" && "$STEWARD" --dry-run) >/dev/null 2>&1 || { rm -fR "$tmpdir"; return 1; };
	rm -fR "$tmpdir";
	grep -q "pkg-from-default" /tmp/steward/apt.pkgs || return 1;
}

test:cli:dry-run-no-exec() {
	local output;
	output=$(cd "$SRC_DIR" && "$STEWARD" --dry-run <<<"steward:apt vim" 2>&1);
	# dry-run should cat scripts, not source them
	# check that we see the script content printed
	[[ "$output" == *"apt"* ]] || return 1;
}

test:cli:task-runs-only-named() {
	reset;
	local tmpfile=$(mktemp);
	cat > "$tmpfile" <<'STEW'
alpha() { steward:apt pkg-alpha; }
beta()  { steward:apt pkg-beta; }
STEW
	(cd "$SRC_DIR" && "$STEWARD" --dry-run --task alpha "$tmpfile") >/dev/null 2>&1 || { rm -f "$tmpfile"; return 1; };
	rm -f "$tmpfile";
	grep -q "pkg-alpha" /tmp/steward/apt.pkgs || return 1;
	grep -q "pkg-beta" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:cli:task-without-flag-runs-all() {
	reset;
	local tmpfile=$(mktemp);
	cat > "$tmpfile" <<'STEW'
alpha() { steward:apt pkg-alpha; }
beta()  { steward:apt pkg-beta; }
STEW
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmpfile") >/dev/null 2>&1 || { rm -f "$tmpfile"; return 1; };
	rm -f "$tmpfile";
	grep -q "pkg-alpha" /tmp/steward/apt.pkgs || return 1;
	grep -q "pkg-beta" /tmp/steward/apt.pkgs || return 1;
}

test:cli:help() {
	local out rc;
	out=$(cd "$SRC_DIR" && "$STEWARD" --help 2>&1) && rc=0 || rc=$?;
	[[ $rc -eq 0 ]] || return 1;
	[[ "$out" == *"USAGE"* && "$out" == *"SYNTAX"* && "$out" == *"Stewardfile"* ]] || return 1;
}

test:cli:namespace-prefix() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run --namespace "st:" <<<'st:apt pkg-namespaced') >/dev/null 2>&1 || return 1;
	grep -qx "pkg-namespaced" /tmp/steward/apt.pkgs || return 1;
}

test:cli:trace-app() {
	reset;
	local err;
	err=$( (cd "$SRC_DIR" && "$STEWARD" --dry-run --trace app <<<'steward:apt pkg-traced') 2>&1 >/dev/null ) || return 1;
	grep -qx "pkg-traced" /tmp/steward/apt.pkgs || return 1;
	[[ "$err" == *"steward"* ]] || return 1;
}

test:cli:stewardfile-dist-fallback() {
	reset;
	local tmpdir; tmpdir=$(mktemp -d);
	echo 'steward:apt pkg-from-dist' > "$tmpdir/Stewardfile.dist";
	ln -s "$SRC_DIR/.deps" "$tmpdir/.deps";
	(cd "$tmpdir" && "$STEWARD" --dry-run) >/dev/null 2>&1 || { rm -fR "$tmpdir"; return 1; };
	rm -fR "$tmpdir";
	grep -qx "pkg-from-dist" /tmp/steward/apt.pkgs || return 1;
}

test:cli:task-keyword-alias() {
	reset;
	local tmpfile; tmpfile=$(mktemp);
	cat > "$tmpfile" <<'STEW'
task alpha() { apt pkg-via-task-keyword; }
STEW
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmpfile") >/dev/null 2>&1 || { rm -f "$tmpfile"; return 1; };
	rm -f "$tmpfile";
	grep -qx "pkg-via-task-keyword" /tmp/steward/apt.pkgs || return 1;
}

test:cli:exposes-arch-and-os-release() {
	reset;
	local tmpfile; tmpfile=$(mktemp);
	echo 'steward:apt "pkg-$ARCH-$ID-$VERSION_CODENAME"' > "$tmpfile";
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmpfile") >/dev/null 2>&1 || { rm -f "$tmpfile"; return 1; };
	rm -f "$tmpfile";
	# shellcheck source=/dev/null
	local arch id codename; arch=$(dpkg --print-architecture); . /etc/os-release; id="$ID"; codename="$VERSION_CODENAME";
	grep -qx "pkg-$arch-$id-$codename" /tmp/steward/apt.pkgs || return 1;
}

test:cli:exposes-stewardfile-dir() {
	reset;
	local tmpfile; tmpfile=$(mktemp);
	echo 'steward:apt "pkg-${STEWARDFILE_DIR//\//-}"' > "$tmpfile";
	(cd "$SRC_DIR" && "$STEWARD" --dry-run "$tmpfile") >/dev/null 2>&1 || { rm -f "$tmpfile"; return 1; };
	rm -f "$tmpfile";
	grep -q "^pkg--" /tmp/steward/apt.pkgs || return 1;
}

test:cli:wipes-stale-manifests() {
	reset;
	touch /tmp/steward/stale-marker;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run <<<'steward:apt pkg-fresh') >/dev/null 2>&1 || return 1;
	[[ ! -e /tmp/steward/stale-marker ]] || return 1;
	grep -qx "pkg-fresh" /tmp/steward/apt.pkgs || return 1;
}

test:cli:deduplicates-manifests() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run <<<$'steward:apt dup-pkg\nsteward:apt dup-pkg\nsteward:apt other-pkg') >/dev/null 2>&1 || return 1;
	[[ $(grep -cx "dup-pkg" /tmp/steward/apt.pkgs) -eq 1 ]] || return 1;
	[[ $(wc -l < /tmp/steward/apt.pkgs) -eq 2 ]] || return 1;
}

test:cli:missing-file-fails() {
	reset;
	(cd "$SRC_DIR" && "$STEWARD" --dry-run /nonexistent/Stewardfile) >/dev/null 2>&1 && return 1;
	return 0;
}

test:cli:sourced-exports-without-running() {
	local out;
	out=$(cd "$SRC_DIR" && bash -c 'source ./steward >/dev/null 2>&1; declare -F steward:apt >/dev/null && echo EXPORTED; [[ -e /tmp/steward/apt.pkgs ]] && echo APPLIED');
	[[ "$out" == "EXPORTED" ]] || return 1;
}

