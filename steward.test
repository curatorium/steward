	APP_ENV=prod steward:in-dev steward:apt vim-prod;
	grep -q "vim-prod" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:in-dev:skips-on-unset() {
	reset;
	steward:in-dev steward:apt vim-unset;
	grep -q "vim-unset" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
