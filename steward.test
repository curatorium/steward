# steward:on-amd64 / steward:on-arm64 Tests
#------------------------------------------------------------------------------

test:on-amd64:executes-on-match() {
	reset;
	ARCH=amd64 steward:on-amd64 steward:apt vim-amd64 || return 1;
	grep -q "vim-amd64" /tmp/steward/apt.pkgs || return 1;
}

test:on-amd64:skips-on-mismatch() {
	reset;
	ARCH=arm64 steward:on-amd64 steward:apt vim-amd64;
	grep -q "vim-amd64" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:on-arm64:executes-on-match() {
	reset;
	ARCH=arm64 steward:on-arm64 steward:apt vim-arm64 || return 1;
	grep -q "vim-arm64" /tmp/steward/apt.pkgs || return 1;
}

test:on-arm64:skips-on-mismatch() {
	reset;
	ARCH=amd64 steward:on-arm64 steward:apt vim-arm64;
	grep -q "vim-arm64" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

test:on-amd64:does-not-glob() {
	reset;
	touch "$TEST_DIR/decoy-a" "$TEST_DIR/decoy-b";
	ARCH=amd64 steward:on-amd64 steward:apt '*' || return 1;
	grep -qxF '*' /tmp/steward/apt.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/apt.pkgs) -eq 1 ]] || return 1;
}

test:on-amd64:preserves-whitespace() {
	reset;
	ARCH=amd64 steward:on-amd64 steward:apt 'pkg with space' || return 1;
	grep -qxF 'pkg with space' /tmp/steward/apt.pkgs || return 1;
}

