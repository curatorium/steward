cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1;
source ./libs/test;
source ./steward;
shopt -u inherit_errexit; # Allow t() to capture non-zero exits in command substitutions

# Helper: reset /tmp/steward between tests
reset() {
	rm -fR /tmp/steward;
	mkdir -p /tmp/steward;
}

# Helper: check if pattern exists in any file under /tmp/steward
generated() {
	grep -rq "$1" /tmp/steward 2>/dev/null;
}

# steward:key Tests
#------------------------------------------------------------------------------

test:key:valid() {
	reset;
	steward:key docker https://download.docker.com/linux/ubuntu/gpg || return 1;
	generated "download.docker.com" || return 1;
	generated "docker.gpg" || return 1;
}

test:key:missing-name() {
	reset;
	local ARGS=();
	steward:key 2>/dev/null && return 1;
	return 0;
}

test:key:missing-url() {
	reset;
	local ARGS=(docker);
	steward:key docker 2>/dev/null && return 1;
	return 0;
}

# steward:src Tests
#------------------------------------------------------------------------------

test:src:valid-full() {
	reset;
	steward:src docker https://download.docker.com/linux/ubuntu jammy stable || return 1;
	generated "download.docker.com" || return 1;
	generated "jammy" || return 1;
	generated "stable" || return 1;
}

test:src:valid-deb-url() {
	reset;
	steward:src https://example.com/package.deb || return 1;
	generated "example.com" || return 1;
	generated "dpkg -i" || return 1;
}

test:src:no-key-flag() {
	reset;
	steward:src --no-key ppa https://ppa.example.com jammy main || return 1;
	generated "signed-by" && return 1;
	return 0;
}

test:src:missing-name() {
	reset;
	steward:src 2>/dev/null && return 1;
	return 0;
}

# steward:apt Tests
#------------------------------------------------------------------------------

test:apt:valid() {
	reset;
	steward:apt vim || return 1;
	grep -q "^vim$" /tmp/steward/packages || return 1;
}

test:apt:versioned() {
	reset;
	steward:apt "vim=2:8.2.3995-1" || return 1;
	grep -q "vim=2:8.2.3995-1" /tmp/steward/packages || return 1;
}

test:apt:try-flag() {
	reset;
	steward:apt --try optional-pkg || return 1;
	grep -q "optional-pkg" /tmp/steward/packages? || return 1;
}

test:apt:missing-name() {
	reset;
	steward:apt 2>/dev/null && return 1;
	return 0;
}

# steward:deb Tests
#------------------------------------------------------------------------------

test:deb:valid() {
	reset;
	steward:deb https://example.com/package.deb || return 1;
	generated "example.com" || return 1;
	generated "dpkg -i" || return 1;
}

test:deb:try-flag() {
	reset;
	steward:deb --try https://example.com/package.deb || return 1;
	generated "example.com" || return 1;
}

test:deb:missing-url() {
	reset;
	steward:deb 2>/dev/null && return 1;
	return 0;
}

test:deb:invalid-url() {
	reset;
	steward:deb /local/path.deb 2>/dev/null && return 1;
	return 0;
}

# steward:bin Tests
#------------------------------------------------------------------------------

test:bin:valid() {
	reset;
	steward:bin jq https://github.com/jqlang/jq/releases/download/jq-1.7/jq-linux-amd64 || return 1;
	generated "jq" || return 1;
	generated "github.com" || return 1;
	generated "/usr/local/bin" || return 1;
}

test:bin:missing-name() {
	reset;
	steward:bin 2>/dev/null && return 1;
	return 0;
}

test:bin:missing-url() {
	reset;
	steward:bin jq 2>/dev/null && return 1;
	return 0;
}

# steward:ext Tests
#------------------------------------------------------------------------------

test:ext:valid() {
	reset;
	steward:ext https://get.docker.com || return 1;
	generated "get.docker.com" || return 1;
}

test:ext:with-shell() {
	reset;
	steward:ext https://get.docker.com sh || return 1;
	generated "get.docker.com" || return 1;
	generated "'sh'" || return 1;
}

test:ext:missing-url() {
	reset;
	steward:ext 2>/dev/null && return 1;
	return 0;
}

# steward:defer Tests
#------------------------------------------------------------------------------

test:defer:valid() {
	reset;
	steward:defer setup <<<"echo hello";
	generated "echo hello" || return 1;
	[[ -f /tmp/steward/100-deferred-setup.sh ]] || return 1;
}

test:defer:custom-order() {
	reset;
	steward:defer :050 early <<<"echo first";
	[[ -f /tmp/steward/050-deferred-early.sh ]] || return 1;
}

test:defer:no-name() {
	reset;
	steward:defer <<<"echo anonymous";
	generated "echo anonymous" || return 1;
}

# steward:amd64 / steward:arm64 Tests
#------------------------------------------------------------------------------

test:amd64:executes-on-match() {
	reset;
	ARCH=amd64 steward:amd64 steward:apt vim-amd64 || return 1;
	grep -q "vim-amd64" /tmp/steward/packages || return 1;
}

test:amd64:skips-on-mismatch() {
	reset;
	ARCH=arm64 steward:amd64 steward:apt vim-amd64;
	grep -q "vim-amd64" /tmp/steward/packages 2>/dev/null && return 1;
	return 0;
}

test:arm64:executes-on-match() {
	reset;
	ARCH=arm64 steward:arm64 steward:apt vim-arm64 || return 1;
	grep -q "vim-arm64" /tmp/steward/packages || return 1;
}

test:arm64:skips-on-mismatch() {
	reset;
	ARCH=amd64 steward:arm64 steward:apt vim-arm64;
	grep -q "vim-arm64" /tmp/steward/packages 2>/dev/null && return 1;
	return 0;
}

# steward:include Tests
#------------------------------------------------------------------------------

test:include:local-file() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt included-pkg' > "$tmpfile";
	steward:include "$tmpfile" || return 1;
	rm -f "$tmpfile";
	grep -q "included-pkg" /tmp/steward/packages || return 1;
}

test:include:missing-file() {
	reset;
	steward:include /nonexistent/file 2>/dev/null && return 1;
	return 0;
}

# Command Interface Tests (using --dry-run to avoid sudo)
#------------------------------------------------------------------------------

test:cli:file-args() {
	reset;
	local tmp1=$(mktemp) tmp2=$(mktemp);
	echo 'steward:apt pkg-from-file1' > "$tmp1";
	echo 'steward:apt pkg-from-file2' > "$tmp2";
	./steward --dry-run "$tmp1" "$tmp2" >/dev/null 2>&1 || return 1;
	rm -f "$tmp1" "$tmp2";
	grep -q "pkg-from-file1" /tmp/steward/packages || return 1;
	grep -q "pkg-from-file2" /tmp/steward/packages || return 1;
}

test:cli:pipe-cat() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt pkg-from-pipe' > "$tmpfile";
	cat "$tmpfile" | ./steward --dry-run >/dev/null 2>&1 || return 1;
	rm -f "$tmpfile";
	grep -q "pkg-from-pipe" /tmp/steward/packages || return 1;
}

test:cli:redirect-file() {
	reset;
	local tmpfile=$(mktemp);
	echo 'steward:apt pkg-from-redirect' > "$tmpfile";
	./steward --dry-run < "$tmpfile" >/dev/null 2>&1 || return 1;
	rm -f "$tmpfile";
	grep -q "pkg-from-redirect" /tmp/steward/packages || return 1;
}

test:cli:herestring() {
	reset;
	./steward --dry-run <<<"steward:apt pkg-from-herestring" >/dev/null 2>&1 || return 1;
	grep -q "pkg-from-herestring" /tmp/steward/packages || return 1;
}

test:cli:process-substitution() {
	reset;
	./steward --dry-run < <(echo "steward:apt pkg-from-procsub") >/dev/null 2>&1 || return 1;
	grep -q "pkg-from-procsub" /tmp/steward/packages || return 1;
}

test:cli:heredoc() {
	reset;
	./steward --dry-run <<STEW >/dev/null 2>&1 || return 1;
steward:apt pkg-from-heredoc
STEW
	grep -q "pkg-from-heredoc" /tmp/steward/packages || return 1;
}

test:cli:default-stewardfile() {
	reset;
	local tmpdir=$(mktemp -d);
	echo 'steward:apt pkg-from-default' > "$tmpdir/Stewardfile";
	cp "$OLDPWD/args" "$tmpdir/args";
	(cd "$tmpdir" && "$OLDPWD/steward" --dry-run) >/dev/null 2>&1 || { rm -fR "$tmpdir"; return 1; };
	rm -fR "$tmpdir";
	grep -q "pkg-from-default" /tmp/steward/packages || return 1;
}

test:cli:dry-run-no-exec() {
	local output;
	output=$(./steward --dry-run <<<"steward:apt vim" 2>&1);
	# dry-run should cat scripts, not source them
	# check that we see the script content printed
	[[ "$output" == *"apt"* ]] || return 1;
}

# Output
#------------------------------------------------------------------------------

cat <<MD
# steward Test Results

## steward:key

Scenario     | Invocation                      | Expected                  | ✓/✗
-------------|---------------------------------|---------------------------|----
valid        | key docker https://example/gpg  | URL + name in output      | $(t test:key:valid)
missing-name | key                             | error                     | $(t test:key:missing-name)
missing-url  | key docker                      | error                     | $(t test:key:missing-url)

---

## steward:src

Scenario      | Invocation                              | Expected                    | ✓/✗
--------------|-----------------------------------------|-----------------------------|----
valid-full    | src docker https://repo jammy stable    | repo + dist + comp in output| $(t test:src:valid-full)
valid-deb-url | src https://example.com/pkg.deb         | URL + dpkg in output        | $(t test:src:valid-deb-url)
no-key-flag   | src --no-key ppa https://repo jammy     | no signed-by in output      | $(t test:src:no-key-flag)
missing-name  | src                                     | error                       | $(t test:src:missing-name)

---

## steward:apt

Scenario     | Invocation          | Expected                 | ✓/✗
-------------|---------------------|--------------------------|----
valid        | apt vim             | vim in packages file     | $(t test:apt:valid)
versioned    | apt vim=2:8.2       | version preserved        | $(t test:apt:versioned)
try-flag     | apt --try pkg       | pkg in packages? file    | $(t test:apt:try-flag)
missing-name | apt                 | error                    | $(t test:apt:missing-name)

---

## steward:deb

Scenario    | Invocation                       | Expected            | ✓/✗
------------|----------------------------------|---------------------|----
valid       | deb https://example.com/pkg.deb  | URL + dpkg in output| $(t test:deb:valid)
try-flag    | deb --try https://example/pkg.deb| success             | $(t test:deb:try-flag)
missing-url | deb                              | error               | $(t test:deb:missing-url)
invalid-url | deb /local/path.deb              | error               | $(t test:deb:invalid-url)

---

## steward:bin

Scenario     | Invocation                  | Expected                     | ✓/✗
-------------|-----------------------------|------------------------------|----
valid        | bin jq https://example/jq   | name + URL + path in output  | $(t test:bin:valid)
missing-name | bin                         | error                        | $(t test:bin:missing-name)
missing-url  | bin jq                      | error                        | $(t test:bin:missing-url)

---

## steward:ext

Scenario    | Invocation                  | Expected        | ✓/✗
------------|-----------------------------|-----------------|----
valid       | ext https://get.docker.com  | URL in output   | $(t test:ext:valid)
with-shell  | ext https://example.com sh  | shell in output | $(t test:ext:with-shell)
missing-url | ext                         | error           | $(t test:ext:missing-url)

---

## steward:defer

Scenario     | Invocation                   | Expected                   | ✓/✗
-------------|------------------------------|----------------------------|----
valid        | defer setup <<<"echo hello"  | content in 100-deferred-*  | $(t test:defer:valid)
custom-order | defer :050 early <<<"x"      | 050-deferred-* created     | $(t test:defer:custom-order)
no-name      | defer <<<"x"                 | content captured           | $(t test:defer:no-name)

---

## steward:amd64 / steward:arm64

Scenario       | Invocation                  | Expected              | ✓/✗
---------------|-----------------------------|-----------------------|----
amd64-on-amd64 | ARCH=amd64; amd64 apt vim   | vim in packages       | $(t test:amd64:executes-on-match)
amd64-on-arm64 | ARCH=arm64; amd64 apt vim   | vim NOT in packages   | $(t test:amd64:skips-on-mismatch)
arm64-on-arm64 | ARCH=arm64; arm64 apt vim   | vim in packages       | $(t test:arm64:executes-on-match)
arm64-on-amd64 | ARCH=amd64; arm64 apt vim   | vim NOT in packages   | $(t test:arm64:skips-on-mismatch)

---

## steward:include

Scenario     | Invocation             | Expected                  | ✓/✗
-------------|------------------------|---------------------------|----
local-file   | include test.sf        | included content processed| $(t test:include:local-file)
missing-file | include /nonexistent   | error                     | $(t test:include:missing-file)

---

## Command Interface

Scenario      | Invocation                | Expected              | ✓/✗
--------------|---------------------------|-----------------------|----
file-args     | steward file1 file2       | both files processed  | $(t test:cli:file-args)
pipe-cat      | cat file | steward        | stdin processed       | $(t test:cli:pipe-cat)
redirect-file | steward < file            | stdin processed       | $(t test:cli:redirect-file)
herestring    | steward <<<"..."          | content processed     | $(t test:cli:herestring)
process-sub   | steward < <(echo ...)     | content processed     | $(t test:cli:process-substitution)
heredoc       | steward <<STEW...STEW     | content processed     | $(t test:cli:heredoc)
default-file  | steward (with Stewardfile)| Stewardfile used      | $(t test:cli:default-stewardfile)
dry-run       | steward --dry-run         | scripts shown, not run| $(t test:cli:dry-run-no-exec)

MD

# Docker Integration Tests (skip if Docker not available)
#------------------------------------------------------------------------------

DOCKER_IMAGE="ubuntu:24.04"

docker:available() {
	command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1
}

docker:run() {
	docker run --rm -v "$PWD:/app" -w /app "$DOCKER_IMAGE" bash -c "$1"
}

docker:steward() {
	local input="$1"; shift;
	docker run --rm -i -v "$PWD:/app" -w /app "$DOCKER_IMAGE" \
		bash -c '/app/steward '"$*" <<< "$input"
}

docker:steward:verify() {
	local input="$1" verify="$2"; shift 2;
	docker run --rm -i -v "$PWD:/app" -w /app "$DOCKER_IMAGE" \
		bash -c '/app/steward '"$*"' && '"$verify" <<< "$input"
}

test:docker:apt-installs() {
	docker:available || return 2;
	docker:steward:verify "apt curl" "curl --version" >/dev/null 2>&1 || return 1;
}

test:docker:apt-try-missing() {
	docker:available || return 2;
	docker:steward "apt --try nonexistent-pkg-12345" >/dev/null 2>&1 || return 1;
}

test:docker:bin-downloads() {
	docker:available || return 2;
	docker:steward:verify "bin jq https://github.com/jqlang/jq/releases/download/jq-1.7.1/jq-linux-amd64" "jq --version" >/dev/null 2>&1 || return 1;
}

test:docker:defer-executes() {
	docker:available || return 2;
	local output;
	output=$(docker:steward 'defer test <<< "echo DEFER_MARKER"' 2>&1) || return 1;
	[[ "$output" == *"DEFER_MARKER"* ]] || return 1;
}

test:docker:include-file() {
	docker:available || return 2;
	echo "steward:apt wget" > .include-test-fixture;
	docker:steward:verify "include .include-test-fixture" "wget --version" >/dev/null 2>&1;
	local rc=$?; rm -f .include-test-fixture; return $rc;
}

if docker:available; then
cat <<MD

---

## Docker Integration Tests

> Running in: $DOCKER_IMAGE

Scenario       | Invocation                   | Expected              | ✓/✗
---------------|------------------------------|-----------------------|----
apt-installs   | apt curl                     | curl works            | $(t test:docker:apt-installs)
apt-try-missing| apt --try nonexistent        | exits 0               | $(t test:docker:apt-try-missing)
bin-downloads  | bin jq https://...           | jq works              | $(t test:docker:bin-downloads)
defer-executes | defer <<< "echo X"           | X in output           | $(t test:docker:defer-executes)
include-file   | include fixtures/test.sf     | included pkg works    | $(t test:docker:include-file)

MD
else
cat <<MD

---

## Docker Integration Tests

> ⚠️ Skipped: Docker not available

MD
fi

summary;
