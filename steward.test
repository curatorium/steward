cmd-failure     | guard --cmd 'false'             | continues execution           | $(t guard:cmd-failure)
cmd-multi-word  | guard --cmd 'test -d /tmp && …' | exits subshell (skip)         | $(t guard:cmd-multi-word)
force-file      | force=true; guard --file exists | guard bypassed                | $(t guard:force-bypasses-file)
force-dir       | force=true; guard --dir /tmp    | guard bypassed                | $(t guard:force-bypasses-dir)
force-pkg       | force=true; guard --pkg bash    | guard bypassed                | $(t guard:force-bypasses-pkg)
force-cmd       | force=true; guard --cmd 'true'  | guard bypassed                | $(t guard:force-bypasses-cmd)
