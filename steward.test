defer-order     | defer-10-a.sh, defer-50-b.sh        | executed in ord order             | $(t apply:defer:runs-in-ord-order)
defer-failure   | defer script exits non-zero         | ERROR on stderr, exit 1           | $(t apply:defer:aborts-on-failure)
hook-stage      | before-apt, after-apt, before-npm   | only the named stage runs         | $(t apply:hook:runs-matching-stage-only)
hook-order      | hook-before-apt-10 / -50            | executed in ord order             | $(t apply:hook:runs-in-ord-order)
hook-failure    | hook script exits non-zero          | ERROR on stderr, exit 1           | $(t apply:hook:aborts-on-failure)
hook-empty      | no hook scripts for stage           | no-op, returns 0                  | $(t apply:hook:noop-without-scripts)

---

## steward::apply:prereqs / :clean-up / dry-run

Scenario         | Invocation                          | Expected                                | ✓/✗
-----------------|-------------------------------------|-----------------------------------------|----
cache-dir        | apply:prereqs                       | /var/cache/steward created              | $(t apply:prereqs:creates-cache-dir)
lists-empty      | apply:prereqs (no apt lists)        | apt update                              | $(t apply:prereqs:updates-when-lists-empty)
lists-present    | apply:prereqs (apt lists present)   | no apt update                           | $(t apply:prereqs:skips-update-when-lists-present)
curl-gpg-missing | apply:prereqs (empty PATH)          | installs apt-transport-https/curl/gpg   | $(t apply:prereqs:installs-curl-and-gpg-when-missing)
outside-buildkit | apply:clean-up (plain container)    | no-op, nothing removed                  | $(t apply:clean-up:skips-outside-buildkit)
temp-removed     | apt --temp build-dep; apt vim       | build-dep removed                       | $(t apply:clean-up:removes-temp-packages)
explicit-kept    | apt --temp build-dep; apt vim       | vim never removed                       | $(t apply:clean-up:keeps-explicitly-requested-packages)
temp-alone       | apt --temp build-dep                | build-dep removed                       | $(t apply:clean-up:removes-lone-temp-package)
try-temp         | apt --try --temp build-dep          | build-dep removed                       | $(t apply:clean-up:removes-try-temp-package)
mounted-caches   | apply:clean-up (caches mounted)     | apt clean skipped, lists kept           | $(t apply:clean-up:keeps-mounted-caches)
dry-run          | dry-run (apt.pkgs + key.lst)        | every manifest printed with a header    | $(t dry-run:prints-every-manifest)

---

## steward::prereq:*

Scenario         | Invocation                         | Expected                                | ✓/✗
-----------------|------------------------------------|-----------------------------------------|----
zip-unused       | prereq:zip (no zip.pkgs)           | nothing scheduled                       | $(t prereq:zip:noop-without-manifest)
zip-missing      | prereq:zip (unzip absent)          | apt --temp unzip                        | $(t prereq:zip:schedules-unzip-when-missing)
zip-present      | prereq:zip (unzip present)         | nothing scheduled                       | $(t prereq:zip:skips-when-unzip-present)
npm-plain        | prereq:npm (NODEVS unset)          | apt nodejs, no repo                     | $(t prereq:npm:apt-nodejs-without-nodevs)
npm-nodevs       | prereq:npm (NODEVS=20)             | nodesource key + node_20.x repo         | $(t prereq:npm:nodesource-with-nodevs)
composer-debian  | prereq:composer (ID=debian)        | sury repo for the codename              | $(t prereq:composer:sury-on-debian)
composer-ubuntu  | prereq:composer (ID=ubuntu)        | ondrej PPA for the codename             | $(t prereq:composer:ondrej-ppa-on-ubuntu)
composer-phpvs   | prereq:composer (PHPVS=8.2)        | php8.2-cli scheduled                    | $(t prereq:composer:honours-phpvs)
composer-present | prereq:composer (php present)      | nothing scheduled                       | $(t prereq:composer:skips-when-php-present)
helm-missing     | prereq:helm (helm absent)          | buildkite key + repo + apt helm         | $(t prereq:helm:schedules-repo-and-package)
helm-present     | prereq:helm (helm present)         | nothing scheduled                       | $(t prereq:helm:skips-when-present)
pip-missing      | prereq:pip (pip3 absent)           | apt --temp python3-pip + python3-venv   | $(t prereq:pip:schedules-temp-python)
go-missing       | prereq:go (go absent)              | apt golang                              | $(t prereq:go:schedules-golang)
go-present       | prereq:go (go present)             | nothing scheduled                       | $(t prereq:go:skips-when-present)

MD

# Docker Integration Tests (skip if Docker not available)
#------------------------------------------------------------------------------

DOCKER_IMAGE="ubuntu:24.04"
DOCKER_BUILD_CTX="/tmp/docker-build-steward"

DOCKER="docker"
docker info >/dev/null 2>&1 || DOCKER="sudo -n docker"
DOCKER_HOST_DIR="${DOCKER_HOST_DIR:-$SRC_DIR}"

docker:available() {
	command -v docker >/dev/null 2>&1 && $DOCKER info >/dev/null 2>&1
}

docker:run() {
	$DOCKER run --rm -v "$DOCKER_HOST_DIR:/app" -w /app "$DOCKER_IMAGE" bash -c "$1"
}

docker:steward() {
	local input="$1"; shift;
	$DOCKER run --rm -i -v "$DOCKER_HOST_DIR:/app" -w /app "$DOCKER_IMAGE" \
		bash -c '/app/steward '"$*" <<< "$input"
}

docker:steward:verify() {
	local input="$1" verify="$2"; shift 2;
	$DOCKER run --rm -i -v "$DOCKER_HOST_DIR:/app" -w /app "$DOCKER_IMAGE" \
		bash -c '/app/steward '"$*"' && '"$verify" <<< "$input"
}

# Fixture image: the artefacts steward downloads, plus an http server for them,
# so the download-and-install stages run against known bytes, not the internet.
DOCKER_FIXTURE_IMAGE="steward-fixtures:test"
DOCKER_FIXTURE_CTX="/tmp/steward-fixtures"

docker:fixtures() {
	$DOCKER image inspect "$DOCKER_FIXTURE_IMAGE" >/dev/null 2>&1 && return 0;

	rm -fR "$DOCKER_FIXTURE_CTX"; mkdir -p "$DOCKER_FIXTURE_CTX";
	cat > "$DOCKER_FIXTURE_CTX/Dockerfile" <<-'DOCKERFILE'
		FROM ubuntu:24.04
		RUN apt-get update -qq && apt-get install -qqy --no-install-recommends \
			ca-certificates curl gpg gpg-agent python3 zip sudo
		RUN set -e; \
			mkdir -p /fixtures /build/bin /build/deb/DEBIAN; \
			printf '#!/bin/sh\necho MYTOOL_OK\n' > /build/bin/mytool; \
			chmod +x /build/bin/mytool; \
			cp /build/bin/mytool /fixtures/mybin; \
			tar -czf /fixtures/tool.tgz -C /build bin; \
			(cd /build && zip -qr /fixtures/tool.zip bin); \
			printf '#!/bin/sh\necho EXT_OK $*\n' > /fixtures/installer.sh; \
			printf 'steward:apt wget\n' > /fixtures/remote.Stewardfile; \
			printf 'Package: steward-fixture\nVersion: 1.0\nArchitecture: all\nMaintainer: steward <t@example.com>\nDescription: fixture package\n' > /build/deb/DEBIAN/control; \
			dpkg-deb --build /build/deb /fixtures/fixture.deb
		RUN gpg --batch --passphrase "" --quick-generate-key "steward fixture <fixture@example.com>" default default never && \
			gpg --armor --export fixture@example.com > /fixtures/key.asc && \
			gpg --export fixture@example.com > /fixtures/key.gpg
		RUN useradd -m -s /bin/bash tester && \
			echo "tester ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/tester
	DOCKERFILE

	$DOCKER build -t "$DOCKER_FIXTURE_IMAGE" "$DOCKER_FIXTURE_CTX" >/dev/null 2>&1;
}

# Runs a Stewardfile inside the fixture image, then evaluates a verification
# fragment. Both are passed through the environment so quoting survives intact.
docker:fixture:steward() {
	local input="$1"; shift;
	local verify="${1:-true}"; (($# > 0)) && shift;
	$DOCKER run --rm -i -v "$DOCKER_HOST_DIR:/app" -w /app \
		-e STEWARD_ARGS="$*" -e STEWARD_VERIFY="$verify" -e STEWARD_USER="${STEWARD_RUN_AS:-root}" \
		"$DOCKER_FIXTURE_IMAGE" bash -c '
			python3 -m http.server 8000 --directory /fixtures >/dev/null 2>&1 &
			until curl -sfo /dev/null http://127.0.0.1:8000/; do sleep 0.1; done;
			cat > /tmp/in.Stewardfile;
			if [[ "$STEWARD_USER" == root ]]; then
				/app/steward $STEWARD_ARGS /tmp/in.Stewardfile || exit 1;
			else
				chmod 0644 /tmp/in.Stewardfile;
				su "$STEWARD_USER" -c "cd /app && ./steward $STEWARD_ARGS /tmp/in.Stewardfile" || exit 1;
			fi
			eval "$STEWARD_VERIFY"' <<< "$input"
}

test:docker:apt-installs() {
	docker:available || return 2;
	docker:steward:verify "apt curl" "curl --version" >/dev/null 2>&1 || return 1;
}

test:docker:apt-try-missing() {
	docker:available || return 2;
	docker:steward "apt --try nonexistent-pkg-12345" >/dev/null 2>&1 || return 1;
}

test:docker:bin-downloads() {
	docker:available || return 2;
	docker:steward:verify "bin jq https://github.com/jqlang/jq/releases/download/jq-1.8.1/jq-linux-amd64" "jq --version" >/dev/null 2>&1 || return 1;
}

test:docker:defer-executes() {
	docker:available || return 2;
	local output;
	output=$(docker:steward 'defer test <<< "echo DEFER_MARKER"' 2>&1) || return 1;
	[[ "$output" == *"DEFER_MARKER"* ]] || return 1;
}

test:docker:include-file() {
	docker:available || return 2;
	echo "steward:apt wget" > "$SRC_DIR/.include-test-fixture";
	docker:steward:verify "include .include-test-fixture" "wget --version" >/dev/null 2>&1;
	local rc=$?; rm -f "$SRC_DIR/.include-test-fixture"; return $rc;
}

test:docker:key-dearmors-ascii-key() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"key fixture http://127.0.0.1:8000/key.asc" \
		"test -f /usr/share/keyrings/fixture.gpg &&
		 ! grep -q BEGIN /usr/share/keyrings/fixture.gpg &&
		 test \"\$(stat -c %a:%U:%G /usr/share/keyrings/fixture.gpg)\" = 644:root:root" \
		>/dev/null 2>&1 || return 1;
}

test:docker:key-copies-binary-key() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"key fixture http://127.0.0.1:8000/key.gpg" \
		"cmp -s /usr/share/keyrings/fixture.gpg /fixtures/key.gpg" \
		>/dev/null 2>&1 || return 1;
}

test:docker:src-writes-source-list() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"src myrepo http://packages.example.com/repo jammy main universe" \
		"grep -qxF \"deb [signed-by=/usr/share/keyrings/myrepo.gpg] http://packages.example.com/repo jammy main universe\" /etc/apt/sources.list.d/myrepo.list &&
		 test \"\$(stat -c %a:%U:%G /etc/apt/sources.list.d/myrepo.list)\" = 644:root:root" \
		>/dev/null 2>&1 || return 1;
}

test:docker:src-no-key-omits-signed-by() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"src --no-key myrepo http://packages.example.com/repo jammy main" \
		"! grep -q signed-by /etc/apt/sources.list.d/myrepo.list" \
		>/dev/null 2>&1 || return 1;
}

test:docker:src-deb-url-installs() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"src http://127.0.0.1:8000/fixture.deb" \
		"dpkg -s steward-fixture" \
		>/dev/null 2>&1 || return 1;
}

test:docker:deb-installs() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"deb http://127.0.0.1:8000/fixture.deb" \
		"dpkg -s steward-fixture" \
		>/dev/null 2>&1 || return 1;
}

test:docker:bin-installs-executable() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"bin mybin http://127.0.0.1:8000/mybin" \
		"test -x /usr/local/bin/mybin && test \"\$(mybin)\" = MYTOOL_OK" \
		>/dev/null 2>&1 || return 1;
}

test:docker:tar-installs-binary() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"tar mytool bin/mytool http://127.0.0.1:8000/tool.tgz" \
		"test \"\$(mytool)\" = MYTOOL_OK && test ! -d /opt/mytool" \
		>/dev/null 2>&1 || return 1;
}

test:docker:tar-keep-retains-archive() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"tar --keep mytool bin/mytool http://127.0.0.1:8000/tool.tgz" \
		"test -d /opt/mytool && test -L /usr/local/bin/mytool && test \"\$(mytool)\" = MYTOOL_OK" \
		>/dev/null 2>&1 || return 1;
}

test:docker:zip-installs-binary() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"zip mytool bin/mytool http://127.0.0.1:8000/tool.zip" \
		"test \"\$(mytool)\" = MYTOOL_OK && test ! -d /opt/mytool" \
		>/dev/null 2>&1 || return 1;
}

test:docker:zip-keep-retains-archive() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"zip --keep mytool bin/mytool http://127.0.0.1:8000/tool.zip" \
		"test -d /opt/mytool && test -L /usr/local/bin/mytool" \
		>/dev/null 2>&1 || return 1;
}

test:docker:ext-runs-installer-with-args() {
	docker:available && docker:fixtures || return 2;
	local output;
	output=$(docker:fixture:steward "ext http://127.0.0.1:8000/installer.sh sh -s -- --flag" 2>&1) || return 1;
	[[ "$output" == *"EXT_OK --flag"* ]] || return 1;
}

test:docker:eager-runs-before-packages() {
	docker:available && docker:fixtures || return 2;
	local output;
	output=$(docker:fixture:steward "$(cat <<-'STEW'
		eager first <<<"touch /tmp/eager.marker"
		steward:apt curl
		defer last <<<"test -f /tmp/eager.marker && echo EAGER_RAN_FIRST"
	STEW
	)" 2>&1) || return 1;
	[[ "$output" == *"EAGER_RAN_FIRST"* ]] || return 1;
}

test:docker:hooks-bracket-their-stage() {
	docker:available && docker:fixtures || return 2;
	local output;
	output=$(docker:fixture:steward "$(cat <<-'STEW'
		hook --before apt pre <<<"echo HOOK_BEFORE_APT"
		hook --after apt post <<<"dpkg -s wget >/dev/null && echo HOOK_AFTER_APT"
		steward:apt wget
	STEW
	)" 2>&1) || return 1;
	[[ "$output" == *"HOOK_BEFORE_APT"* ]] || return 1;
	[[ "$output" == *"HOOK_AFTER_APT"* ]] || return 1;
}

test:docker:guard-skips-satisfied-task() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward "$(cat <<-'STEW'
		skipped() {
			guard --cmd true
			steward:apt wget
		}
	STEW
	)" "! dpkg -s wget" >/dev/null 2>&1 || return 1;
}

test:docker:url-stewardfile-argument() {
	docker:available && docker:fixtures || return 2;
	$DOCKER run --rm -v "$DOCKER_HOST_DIR:/app" -w /app "$DOCKER_FIXTURE_IMAGE" bash -c '
		python3 -m http.server 8000 --directory /fixtures >/dev/null 2>&1 &
		until curl -sfo /dev/null http://127.0.0.1:8000/; do sleep 0.1; done;
		./steward http://127.0.0.1:8000/remote.Stewardfile && dpkg -s wget' >/dev/null 2>&1 || return 1;
}

test:docker:pip-installs-package() {
	docker:available && docker:fixtures || return 2;
	docker:fixture:steward \
		"pip six" \
		"python3 -c \"import six\"" \
		>/dev/null 2>&1 || return 1;
}

test:docker:sudo-reexec-installs() {
	docker:available && docker:fixtures || return 2;
	STEWARD_RUN_AS=tester docker:fixture:steward "apt wget" "dpkg -s wget" >/dev/null 2>&1 || return 1;
}

test:docker:sudo-reexec-keeps-invoking-user() {
	docker:available && docker:fixtures || return 2;
	local output;
	output=$(STEWARD_RUN_AS=tester docker:fixture:steward 'defer whoami <<<"echo INVOKER=$USER HOME=$HOME"' 2>&1) || return 1;
	[[ "$output" == *"INVOKER=tester HOME=/home/tester"* ]] || return 1;
}

test:docker:dockerfile-run() {
	docker:available || return 2;
	rm -fR "$DOCKER_BUILD_CTX"; mkdir -p "$DOCKER_BUILD_CTX";

	# Stewardfile that queues a marker package
	echo 'steward:apt pkg-from-dockerfile' > "$DOCKER_BUILD_CTX/Stewardfile";

	# Dockerfile: steward invoked as a RUN instruction (no stdin piped)
	local s=steward
	cat > "$DOCKER_BUILD_CTX/Dockerfile" <<-DOCKERFILE
		FROM ubuntu:24.04
		COPY $s /app/$s
		COPY .deps /app/.deps
		COPY Stewardfile /app/Stewardfile
		WORKDIR /app
		RUN bash ./$s --dry-run && test -f /tmp/$s/apt.pkgs
	DOCKERFILE

	# Populate build context
	cp "$SRC_DIR/steward" "$DOCKER_BUILD_CTX/steward";
	cp -r "$SRC_DIR/.deps" "$DOCKER_BUILD_CTX/.deps";

	# Build — if stdin detection is broken, steward hangs reading an empty FIFO instead of Stewardfile
	# Timeout: safety net in case the FIFO fix regresses (prevents test suite from hanging)
	timeout 30 $DOCKER build --no-cache "$DOCKER_BUILD_CTX" >/dev/null 2>&1;
	local rc=$?; rm -fR "$DOCKER_BUILD_CTX"; return $rc;
}

test:docker:dockerfile-run-fifo() {
	docker:available || return 2;
	rm -fR "$DOCKER_BUILD_CTX"; mkdir -p "$DOCKER_BUILD_CTX";

	# Stewardfile that queues a marker package
	echo 'steward:apt pkg-from-fifo-test' > "$DOCKER_BUILD_CTX/Stewardfile";

	# Dockerfile: steward invoked directly (./steward, not bash ./steward)
	# Docker attaches a writerless FIFO to stdin during RUN — steward must not hang on it
	local s=steward
	cat > "$DOCKER_BUILD_CTX/Dockerfile" <<-DOCKERFILE
		FROM ubuntu:24.04
		COPY $s /app/$s
		COPY .deps /app/.deps
		COPY Stewardfile /app/Stewardfile
		WORKDIR /app
		RUN ./$s --dry-run && grep -q 'pkg-from-fifo-test' /tmp/$s/apt.pkgs
	DOCKERFILE

	# Populate build context
	cp "$SRC_DIR/steward" "$DOCKER_BUILD_CTX/steward";
	cp -r "$SRC_DIR/.deps" "$DOCKER_BUILD_CTX/.deps";

	# Build — timeout is a safety net; with the fix, steward should finish in under 5 seconds
	timeout 30 $DOCKER build --no-cache "$DOCKER_BUILD_CTX" >/dev/null 2>&1;
	local rc=$?; rm -fR "$DOCKER_BUILD_CTX"; return $rc;
}

# Runs steward for real inside an image build. Only here does /proc/1/mountinfo
# name buildkit, which is what arms the clean-up stage.
docker:buildkit() {
	local stewardfile="$1" assertion="$2";
	rm -fR "$DOCKER_BUILD_CTX"; mkdir -p "$DOCKER_BUILD_CTX";

	printf '%s\n' "$stewardfile" > "$DOCKER_BUILD_CTX/Stewardfile";
	cp "$SRC_DIR/steward" "$DOCKER_BUILD_CTX/steward";
	cp -r "$SRC_DIR/.deps" "$DOCKER_BUILD_CTX/.deps";

	{
		echo "FROM ubuntu:24.04";
		echo "COPY steward /app/steward";
		echo "COPY .deps /app/.deps";
		echo "COPY Stewardfile /app/Stewardfile";
		echo "WORKDIR /app";
		echo "RUN ./steward";
		echo "RUN $assertion";
	} > "$DOCKER_BUILD_CTX/Dockerfile";

	timeout 300 $DOCKER build --no-cache "$DOCKER_BUILD_CTX" >/dev/null 2>&1;
	local rc=$?; rm -fR "$DOCKER_BUILD_CTX"; return $rc;
}

test:docker:buildkit-clean-up-succeeds() {
	docker:available || return 2;
	docker:buildkit "steward:apt --temp jq" "true" || return 1;
}

test:docker:buildkit-removes-temp-package() {
	docker:available || return 2;
	docker:buildkit $'steward:apt --temp jq\nsteward:apt wget' "! command -v jq" || return 1;
}

test:docker:buildkit-keeps-requested-package() {
	docker:available || return 2;
	docker:buildkit $'steward:apt --temp jq\nsteward:apt wget' "command -v wget" || return 1;
}

if docker:available; then
cat <<MD

---

## Docker Integration Tests

> Running in: $DOCKER_IMAGE

Scenario       | Invocation                   | Expected              | ✓/✗
---------------|------------------------------|-----------------------|----
apt-installs   | apt curl                     | curl works            | $(t docker:apt-installs)
apt-try-missing| apt --try nonexistent        | exits 0               | $(t docker:apt-try-missing)
bin-downloads  | bin jq https://...           | jq works              | $(t docker:bin-downloads)
defer-executes | defer <<< "echo X"           | X in output           | $(t docker:defer-executes)
include-file   | include fixtures/test.sf     | included pkg works    | $(t docker:include-file)
dockerfile-run | RUN steward (in Dockerfile)  | reads Stewardfile     | $(t docker:dockerfile-run)
dockerfile-fifo| RUN ./steward (writerless FIFO) | no hang, reads Stewardfile | $(t docker:dockerfile-run-fifo)

### Download-and-install stages (fixture image)

Scenario        | Invocation                              | Expected                              | ✓/✗
----------------|-----------------------------------------|---------------------------------------|----
key-armored     | key fixture http://.../key.asc          | dearmored keyring, 644 root:root      | $(t docker:key-dearmors-ascii-key)
key-binary      | key fixture http://.../key.gpg          | copied verbatim                       | $(t docker:key-copies-binary-key)
src-list        | src myrepo http://... jammy main uni    | sources.list.d entry, 644 root:root   | $(t docker:src-writes-source-list)
src-no-key      | src --no-key myrepo http://... jammy    | no signed-by in the list              | $(t docker:src-no-key-omits-signed-by)
src-deb-url     | src http://.../fixture.deb              | package installed                     | $(t docker:src-deb-url-installs)
deb-installs    | deb http://.../fixture.deb              | package installed                     | $(t docker:deb-installs)
bin-executable  | bin mybin http://.../mybin              | executable in /usr/local/bin, runs    | $(t docker:bin-installs-executable)
tar-installs    | tar mytool bin/mytool http://...tgz     | binary runs, no /opt/mytool           | $(t docker:tar-installs-binary)
tar-keep        | tar --keep mytool bin/mytool ...        | /opt/mytool + symlink                 | $(t docker:tar-keep-retains-archive)
zip-installs    | zip mytool bin/mytool http://...zip     | unzip prereq installed, binary runs   | $(t docker:zip-installs-binary)
zip-keep        | zip --keep mytool bin/mytool ...        | /opt/mytool + symlink                 | $(t docker:zip-keep-retains-archive)
ext-args        | ext http://.../installer.sh sh -s -- --flag | script runs with args             | $(t docker:ext-runs-installer-with-args)
eager-first     | eager marker; apt curl; defer check     | eager ran before packages             | $(t docker:eager-runs-before-packages)
hooks           | hook --before/--after apt               | both hooks ran around the stage       | $(t docker:hooks-bracket-their-stage)
guard-skips     | guard --cmd true; apt wget              | task skipped, wget absent             | $(t docker:guard-skips-satisfied-task)
url-argument    | steward http://.../remote.Stewardfile   | remote Stewardfile processed          | $(t docker:url-stewardfile-argument)
pip-installs    | pip six                                 | python3 -c "import six" works         | $(t docker:pip-installs-package)
sudo-reexec     | ./steward as unprivileged user          | re-execs under sudo, installs         | $(t docker:sudo-reexec-installs)
sudo-user       | defer echo \$USER (run via sudo)        | USER/HOME are the invoking human      | $(t docker:sudo-reexec-keeps-invoking-user)

### BuildKit clean-up (only armed inside an image build)

Scenario         | Invocation                        | Expected                         | ✓/✗
-----------------|-----------------------------------|----------------------------------|----
clean-up-runs    | RUN ./steward (apt --temp jq)     | build succeeds                   | $(t docker:buildkit-clean-up-succeeds)
temp-removed     | apt --temp jq; apt wget           | jq gone from the final image     | $(t docker:buildkit-removes-temp-package)
requested-kept   | apt --temp jq; apt wget           | wget kept in the final image     | $(t docker:buildkit-keeps-requested-package)

MD
else
cat <<MD

---

## Docker Integration Tests

> ⚠️ Skipped: Docker not available

MD
fi
}
