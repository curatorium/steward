test:prereq:go:schedules-golang() {
	reset;
	steward:go github.com/some/pkg || return 1;
	( PATH=; steward::prereq:go; ) || return 1;
	grep -qx "golang" /tmp/steward/apt.pkgs || return 1;
}

test:prereq:go:skips-when-present() {
	reset;
	steward:go github.com/some/pkg || return 1;
	( fake go; steward::prereq:go; ) || return 1;
	[[ ! -f /tmp/steward/apt.pkgs ]] || return 1;
}

