	  PATH="$TEST_DIR/bin"; steward::apply:prereqs; ) || return 1;
	logged "apt install -qqy --no-install-recommends apt-transport-https ca-certificates curl gpg" || return 1;
}

test:apply:clean-up:skips-outside-buildkit() {
	reset;
	printf 'build-dep\n' > /tmp/steward/apt-temp.pkgs;
	printf 'vim\n' > /tmp/steward/apt.pkgs;
	( strict:on; fake apt; fake findmnt; steward::apply:clean-up; ) || return 1;
	logged "apt" && return 1;
	return 0;
}

test:apply:clean-up:removes-temp-packages() {
	reset;
	steward:apt --temp build-dep;
	steward:apt vim;
	steward:apt --try optional;
	( strict:on; fake grep; fake apt; fake findmnt; steward::apply:clean-up; );
	logged "apt remove -qqy build-dep @" || return 1;
}

test:apply:clean-up:keeps-explicitly-requested-packages() {
	reset;
	steward:apt --temp build-dep;
	steward:apt vim;
	( strict:on; fake grep; fake apt; fake findmnt; steward::apply:clean-up; );
	grep -F "apt remove" "$TEST_DIR/cmd.log" 2>/dev/null | grep -q "vim" && return 1;
	return 0;
}

test:apply:clean-up:removes-lone-temp-package() {
	reset;
	steward:apt --temp build-dep;
	( strict:on; fake grep; fake apt; fake findmnt; steward::apply:clean-up; );
	logged "apt remove -qqy build-dep @" || return 1;
}

test:apply:clean-up:removes-try-temp-package() {
	reset;
	steward:apt --try --temp build-dep;
	( strict:on; fake grep; fake apt; fake findmnt; steward::apply:clean-up; );
	logged "apt remove -qqy build-dep @" || return 1;
}

test:apply:clean-up:keeps-mounted-caches() {
	reset;
	( strict:on; fake grep; fake apt; fake findmnt; steward::apply:clean-up; ) || return 1;
	logged "apt clean" && return 1;
	[[ -d /var/lib/apt/lists ]] || return 1;
