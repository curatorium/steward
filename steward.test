# steward::apply:helm
#------------------------------------------------------------------------------

test:apply:helm:upgrade-defaults() {
	reset; printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "helm upgrade --install my-nginx bitnami/nginx --atomic --wait --timeout 60s --namespace default --create-namespace" || return 1;
}

test:apply:helm:pinned-version() {
	reset; printf 'my-nginx\tbitnami/nginx\tdefault\t1.2.3\t60\t\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "--version 1.2.3" || return 1;
}

test:apply:helm:custom-timeout() {
	reset; printf 'my-nginx\tbitnami/nginx\tdefault\t-\t300\t\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "--timeout 300s" || return 1;
}

test:apply:helm:values-file() {
	reset; echo "replicaCount: 3" > /tmp/steward/helm.my-nginx.yml;
	printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t/tmp/steward/helm.my-nginx.yml\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "--values /tmp/steward/helm.my-nginx.yml" || return 1;
}

test:apply:helm:adds-and-updates-repos() {
	reset;
	printf 'bitnami\thttps://charts.bitnami.com/bitnami\n' > /tmp/steward/helm.lst;
	printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "helm repo add bitnami https://charts.bitnami.com/bitnami" || return 1;
	logged "helm repo update" || return 1;
}

test:apply:helm:installs-every-release() {
	reset;
	printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t\nmy-redis\tbitnami/redis\tdata\t-\t60\t\n' > /tmp/steward/helm.pkgs;
	( fake kubectl; fake helm; steward::apply:helm; ) >/dev/null || return 1;
	logged "--install my-nginx bitnami/nginx" || return 1;
	logged "--install my-redis bitnami/redis" || return 1;
}

test:apply:helm:reports-failed-releases() {
	reset; printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t\n' > /tmp/steward/helm.pkgs;
	local out rc;
	out=$( fake kubectl; fake helm 'exit 1'; steward::apply:helm 2>&1 ) && rc=0 || rc=$?;
	[[ $rc -eq 1 ]] || return 1;
	[[ "$out" == *"helm: failed releases: my-nginx"* ]] || return 1;
}

test:apply:helm:times-out-without-kubernetes() {
	reset; printf 'my-nginx\tbitnami/nginx\tdefault\t-\t60\t\n' > /tmp/steward/helm.pkgs;
	local out rc;
	out=$( fake sleep; fake kubectl 'exit 1'; fake helm; steward::apply:helm 2>&1 ) && rc=0 || rc=$?;
	[[ $rc -eq 1 ]] || return 1;
	[[ "$out" == *"timed out waiting for kubernetes"* ]] || return 1;
	logged "helm upgrade" && return 1;
	return 0;
}

# steward::apply:eager / :hook / :defer execution
#------------------------------------------------------------------------------

test:apply:eager:runs-in-ord-order() {
	reset;
	printf 'echo second >> "$TEST_DIR/order.log"\n' > /tmp/steward/eager-50-b.sh;
	printf 'echo first >> "$TEST_DIR/order.log"\n'  > /tmp/steward/eager-10-a.sh;
	steward::apply:eager || return 1;
	[[ "$(cat "$TEST_DIR/order.log")" == $'first\nsecond' ]] || return 1;
}

test:apply:eager:aborts-on-failure() {
	reset;
	printf 'false\n' > /tmp/steward/eager-00-boom.sh;
	local out rc;
	out=$( steward::apply:eager 2>&1 ) && rc=0 || rc=$?;
	[[ $rc -eq 1 ]] || return 1;
	[[ "$out" == *"ERROR: /tmp/steward/eager-00-boom.sh"* ]] || return 1;
}

test:apply:eager:noop-without-scripts() {
	reset;
	steward::apply:eager || return 1;
}

test:apply:defer:runs-in-ord-order() {
	reset;
	printf 'echo second >> "$TEST_DIR/order.log"\n' > /tmp/steward/defer-50-b.sh;
	printf 'echo first >> "$TEST_DIR/order.log"\n'  > /tmp/steward/defer-10-a.sh;
	steward::apply:defer || return 1;
	[[ "$(cat "$TEST_DIR/order.log")" == $'first\nsecond' ]] || return 1;
}

test:apply:defer:aborts-on-failure() {
	reset;
	printf 'false\n' > /tmp/steward/defer-00-boom.sh;
	local out rc;
	out=$( steward::apply:defer 2>&1 ) && rc=0 || rc=$?;
	[[ $rc -eq 1 ]] || return 1;
	[[ "$out" == *"ERROR: /tmp/steward/defer-00-boom.sh"* ]] || return 1;
}

test:apply:hook:runs-matching-stage-only() {
	reset;
	printf 'echo before-apt >> "$TEST_DIR/order.log"\n' > /tmp/steward/hook-before-apt-00-a.sh;
	printf 'echo after-apt  >> "$TEST_DIR/order.log"\n' > /tmp/steward/hook-after-apt-00-b.sh;
	printf 'echo before-npm >> "$TEST_DIR/order.log"\n' > /tmp/steward/hook-before-npm-00-c.sh;
	steward::apply:hook before apt || return 1;
	[[ "$(cat "$TEST_DIR/order.log")" == "before-apt" ]] || return 1;
	steward::apply:hook after apt || return 1;
	[[ "$(cat "$TEST_DIR/order.log")" == $'before-apt\nafter-apt' ]] || return 1;
}

test:apply:hook:runs-in-ord-order() {
	reset;
	printf 'echo second >> "$TEST_DIR/order.log"\n' > /tmp/steward/hook-before-apt-50-b.sh;
	printf 'echo first >> "$TEST_DIR/order.log"\n'  > /tmp/steward/hook-before-apt-10-a.sh;
	steward::apply:hook before apt || return 1;
	[[ "$(cat "$TEST_DIR/order.log")" == $'first\nsecond' ]] || return 1;
}

test:apply:hook:aborts-on-failure() {
	reset;
	printf 'false\n' > /tmp/steward/hook-before-apt-00-boom.sh;
	local out rc;
	out=$( steward::apply:hook before apt 2>&1 ) && rc=0 || rc=$?;
	[[ $rc -eq 1 ]] || return 1;
	[[ "$out" == *"ERROR: /tmp/steward/hook-before-apt-00-boom.sh"* ]] || return 1;
}

test:apply:hook:noop-without-scripts() {
	reset;
	steward::apply:hook before apt || return 1;
}

# steward::apply:prereqs / :clean-up / dry-run
