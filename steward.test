test:dry-run:prints-every-manifest() {
	reset;
	printf 'vim\n' > /tmp/steward/apt.pkgs;
	printf 'docker\thttps://example.com/gpg\n' > /tmp/steward/key.lst;
	local out; out=$(steward::dry-run);
	[[ "$out" == *"=== apt.pkgs ==="* ]] || return 1;
	[[ "$out" == *"=== key.lst ==="* ]] || return 1;
	[[ "$out" == *"vim"* ]] || return 1;
}

# steward::prereq:* scheduling
#------------------------------------------------------------------------------

test:prereq:zip:noop-without-manifest() {
	reset;
	( PATH=; steward::prereq:zip; ) || return 1;
	[[ ! -f /tmp/steward/apt.pkgs ]] || return 1;
}

test:prereq:zip:schedules-unzip-when-missing() {
	reset;
	steward:zip mytool bin/x https://example.com/tool.zip || return 1;
	( PATH=; steward::prereq:zip; ) || return 1;
	grep -qx "unzip" /tmp/steward/apt-temp.pkgs || return 1;
	grep -qx "unzip" /tmp/steward/apt.pkgs 2>/dev/null && return 1;
	return 0;
}

