# steward:ext Tests
#------------------------------------------------------------------------------

test:ext:valid() {
	reset;
	steward:ext https://get.docker.com || return 1;
	generated "get.docker.com" || return 1;
}

test:ext:with-shell() {
	reset;
	steward:ext https://get.docker.com sh || return 1;
	generated "get.docker.com" || return 1;
	grep -qP "\tsh\t" /tmp/steward/ext.pkgs || grep -qP "\tsh$" /tmp/steward/ext.pkgs || return 1;
}

test:ext:with-args() {
	reset;
	steward:ext https://getcomposer.org/installer php -- --2 --install-dir=/usr/local/bin || return 1;
	grep -q "getcomposer.org" /tmp/steward/ext.pkgs || return 1;
	grep -qP "\tphp\t" /tmp/steward/ext.pkgs || return 1;
	grep -q "\-\-install-dir=/usr/local/bin" /tmp/steward/ext.pkgs || return 1;
}

test:ext:missing-url() {
	reset;
	steward:ext 2>/dev/null && return 1;
	return 0;
}

test:ext:defaults-to-bash() {
	reset;
	steward:ext https://get.docker.com || return 1;
	grep -qP "^https://get.docker.com\tbash\t" /tmp/steward/ext.pkgs || return 1;
}

# steward:npm Tests
#------------------------------------------------------------------------------

test:npm:valid() {
	reset;
	steward:npm yarn || return 1;
	grep -qP "^!global\tyarn$" /tmp/steward/npm.pkgs || return 1;
}

test:npm:versioned() {
	reset;
	steward:npm yarn@1.22.0 || return 1;
	grep -qP "^!global\tyarn@1.22.0$" /tmp/steward/npm.pkgs || return 1;
}

test:npm:batched() {
	reset;
	steward:npm yarn || return 1;
	steward:npm typescript || return 1;
	grep -qP "^!global\t.*yarn.*typescript" /tmp/steward/npm.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/npm.pkgs) -eq 1 ]] || return 1;
}

test:npm:not-generated-if-unused() {
	reset;
	[[ ! -f /tmp/steward/npm.pkgs ]] || return 1;
}

test:npm:prereq-skipped-when-present() {
	# Simulate npm being available — no key/src/packages should be generated
	reset;
	echo '#!/bin/bash' > /usr/local/bin/npm && chmod +x /usr/local/bin/npm;
	steward:npm is-odd || { rm -f /usr/local/bin/npm; return 1; };
	steward::prereq:npm || { rm -f /usr/local/bin/npm; return 1; };
	rm -f /usr/local/bin/npm;
	[[ ! -f /tmp/steward/key.lst ]] || return 1;
	[[ ! -f /tmp/steward/src.lst ]] || return 1;
	[[ ! -f /tmp/steward/apt.pkgs ]] || return 1;
	# but the manifest should still be generated
	[[ -f /tmp/steward/npm.pkgs ]] || return 1;
}

test:npm:local-dir() {
	reset;
	steward:npm --dir /app || return 1;
	grep -qP "^/app\t$" /tmp/steward/npm.pkgs || return 1;
}

test:npm:local-dir-with-name() {
	reset;
	steward:npm --dir /app express || return 1;
	grep -qP "^/app\texpress$" /tmp/steward/npm.pkgs || return 1;
}

test:npm:separate-dirs-stay-separate() {
	reset;
	steward:npm --dir /app-a express || return 1;
	steward:npm --dir /app-b react || return 1;
	grep -qP "^/app-a\texpress$" /tmp/steward/npm.pkgs || return 1;
	grep -qP "^/app-b\treact$" /tmp/steward/npm.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/npm.pkgs) -eq 2 ]] || return 1;
}

test:npm:same-dir-batched() {
	reset;
	steward:npm --dir /app express || return 1;
	steward:npm --dir /app react || return 1;
	grep -qP "^/app\texpress react$" /tmp/steward/npm.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/npm.pkgs) -eq 1 ]] || return 1;
}

test:npm:missing-name() {
	reset;
	steward:npm 2>/dev/null && return 1;
	return 0;
}

# steward:composer Tests
#------------------------------------------------------------------------------

test:composer:valid() {
	reset;
	steward:composer laravel/installer || return 1;
	grep -qP "^!global\tlaravel/installer$" /tmp/steward/composer.pkgs || return 1;
	# Hide php so prereqs are generated (apt.pkgs + ext.pkgs)
	PATH= steward::prereq:composer || return 1;
	grep -q "php.*-cli" /tmp/steward/apt.pkgs || return 1;
	grep -q "getcomposer.org" /tmp/steward/ext.pkgs || return 1;
}

test:composer:versioned() {
	reset;
	steward:composer laravel/installer@^4.0 || return 1;
	grep -qP "^!global\tlaravel/installer@\^4\.0$" /tmp/steward/composer.pkgs || return 1;
}

test:composer:batched() {
	reset;
	steward:composer laravel/installer || return 1;
	steward:composer phpstan/phpstan || return 1;
	grep -qP "^!global\t.*laravel/installer.*phpstan/phpstan" /tmp/steward/composer.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/composer.pkgs) -eq 1 ]] || return 1;
}

test:composer:not-generated-if-unused() {
	reset;
	[[ ! -f /tmp/steward/composer.pkgs ]] || return 1;
}

test:composer:local-dir() {
	reset;
	steward:composer --dir /app || return 1;
	grep -qP "^/app\t$" /tmp/steward/composer.pkgs || return 1;
}

test:composer:local-dir-with-name() {
	reset;
	steward:composer --dir /app laravel/installer || return 1;
	grep -qP "^/app\tlaravel/installer$" /tmp/steward/composer.pkgs || return 1;
}

test:composer:separate-dirs-stay-separate() {
	reset;
	steward:composer --dir /app-a laravel/installer || return 1;
	steward:composer --dir /app-b phpstan/phpstan || return 1;
	[[ $(wc -l < /tmp/steward/composer.pkgs) -eq 2 ]] || return 1;
}

test:composer:same-dir-batched() {
	reset;
	steward:composer --dir /app laravel/installer || return 1;
	steward:composer --dir /app phpstan/phpstan || return 1;
	grep -qP "^/app\tlaravel/installer phpstan/phpstan$" /tmp/steward/composer.pkgs || return 1;
	[[ $(wc -l < /tmp/steward/composer.pkgs) -eq 1 ]] || return 1;
}

test:composer:missing-name() {
	reset;
	steward:composer 2>/dev/null && return 1;
	return 0;
}

# steward:helm Tests
#------------------------------------------------------------------------------

test:helm:valid() {
	reset;
	steward:helm default/my-nginx bitnami/nginx || return 1;
	[[ -f /tmp/steward/helm.pkgs ]] || return 1;
	grep -qP "^my-nginx\tbitnami/nginx\tdefault\t-\t60\t$" /tmp/steward/helm.pkgs || return 1;
}

test:helm:with-namespace() {
	reset;
	steward:helm production/my-nginx bitnami/nginx || return 1;
	grep -q "my-nginx" /tmp/steward/helm.pkgs || return 1;
	grep -qP "\tproduction\t" /tmp/steward/helm.pkgs || return 1;
}

test:helm:with-version() {
	reset;
	steward:helm default/my-nginx bitnami/nginx@1.2.3 || return 1;
	grep -q "bitnami/nginx" /tmp/steward/helm.pkgs || return 1;
	grep -qP "\t1\.2\.3\t" /tmp/steward/helm.pkgs || return 1;
}

test:helm:with-timeout() {
	reset;
	steward:helm default/my-nginx bitnami/nginx --timeout 120 || return 1;
	grep -qP "\t120\t" /tmp/steward/helm.pkgs || return 1;
}

test:helm:with-values-stdin() {
	reset;
	steward:helm default/my-nginx bitnami/nginx <<< "replicaCount: 3" || return 1;
	[[ -f /tmp/steward/helm.my-nginx.yml ]] || return 1;
	grep -q "replicaCount: 3" /tmp/steward/helm.my-nginx.yml || return 1;
	grep -q "helm.my-nginx.yml" /tmp/steward/helm.pkgs || return 1;
}

test:helm:with-repo() {
	reset;
	steward:helm default/my-nginx bitnami/nginx https://charts.bitnami.com/bitnami || return 1;
	grep -qP "^bitnami\thttps://charts.bitnami.com/bitnami$" /tmp/steward/helm.lst || return 1;
	[[ -f /tmp/steward/helm.pkgs ]] || return 1;
}

test:helm:repo-dedup() {
	reset;
	steward:helm default/my-nginx bitnami/nginx https://charts.bitnami.com/bitnami || return 1;
	steward:helm default/my-redis bitnami/redis https://charts.bitnami.com/bitnami || return 1;
	sort -u -o /tmp/steward/helm.lst /tmp/steward/helm.lst;
	[[ $(wc -l < /tmp/steward/helm.lst) -eq 1 ]] || return 1;
}

test:helm:guard-once() {
	reset;
	steward:helm default/my-nginx bitnami/nginx || return 1;
	steward:helm default/my-redis bitnami/redis || return 1;
	[[ $(wc -l < /tmp/steward/helm.pkgs) -eq 2 ]] || return 1;
}

test:helm:not-generated-if-unused() {
	reset;
	[[ ! -f /tmp/steward/helm.pkgs ]] || return 1;
}

test:helm:missing-release() {
	reset;
	steward:helm 2>/dev/null && return 1;
	return 0;
}

test:helm:missing-namespace() {
	reset;
	steward:helm my-release bitnami/nginx 2>/dev/null && return 1;
	return 0;
}

test:helm:missing-chart() {
	reset;
	steward:helm default/my-release 2>/dev/null && return 1;
	return 0;
}

test:helm:empty-stdin-leaves-no-values() {
	reset;
	steward:helm default/my-nginx bitnami/nginx < /dev/null || return 1;
	[[ ! -f /tmp/steward/helm.my-nginx.yml ]] || return 1;
	grep -qP "\t60\t$" /tmp/steward/helm.pkgs || return 1;
}

test:helm:version-and-timeout-together() {
	reset;
	steward:helm prod/my-nginx bitnami/nginx@1.2.3 --timeout 300 || return 1;
	grep -qP "^my-nginx\tbitnami/nginx\tprod\t1\.2\.3\t300\t$" /tmp/steward/helm.pkgs || return 1;
}

