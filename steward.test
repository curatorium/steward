test:apply:prereqs:creates-cache-dir() {
	reset;
	( strict:on; fake mkdir; fake find 'echo /var/lib/apt/lists/x_Packages'; fake apt; steward::apply:prereqs; ) || return 1;
	logged "mkdir -p /var/cache/steward" || return 1;
}

test:apply:prereqs:updates-when-lists-empty() {
	reset;
	( strict:on; fake mkdir; fake find; fake apt; steward::apply:prereqs; ) || return 1;
	logged "apt update -qq" || return 1;
}

test:apply:prereqs:skips-update-when-lists-present() {
	reset;
	( strict:on; fake mkdir; fake find 'echo /var/lib/apt/lists/x_Packages'; fake apt; steward::apply:prereqs; ) || return 1;
	logged "apt update" && return 1;
	return 0;
}

test:apply:prereqs:installs-curl-and-gpg-when-missing() {
