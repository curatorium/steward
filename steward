# @name steward
# @type command
# @desc Declarative DSL for installing packages, in a shareable file format called Stewardfile.
#
# @usage steward [...file|url] < Stewardfile
# @usage cat Stewardfile | steward [...file|url]
#
# @opt  [-n|--namespace]	Namespace (keyword prefix).
# @flag [-d|--dry-run]		Dry run -- read the Stewardfiles, check the syntax & parameters, display what commands would be executed.
# @flag [-v|--verbose]		Enable command tracing.
# @flag [-h|--help]		Prints out the usage guide.
#
# @arg [...file|url]	Paths or URLs to process, default: Stewardfile
function steward:main() {
	local ARGS=("$@");
	local namespace=;  args:opt  namespace n;
	local dry_run=;    args:flag dry-run d;
	local verbose=;    args:flag verbose v;
	local help=;       args:flag help h;

	[[ "$verbose" == "true" ]] && set -x;
	[[ "$help" == "true" ]] && steward:help && return;

	steward:init;

	# Allow importing (sourcing) this script
	[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return;


	# Read Stewardfile from stdin if available
	stat -L -c '%F' /dev/stdin 2>/dev/null | grep -P '^(regular file|fifo)$' && ARGS+=("/dev/stdin");

	# Default file to read is Stewardfile
	[[ ${#ARGS[@]} -eq 0 ]] && ARGS+=("Stewardfile");

	(
		steward:use "$namespace";

		# Read each Stewardfile provided
		for file in "${ARGS[@]}"; do
			steward:include "$file";
		done
	);

	steward:apply "$@";
}

function steward:init() {
	set -Eeuo pipefail;
	shopt -s inherit_errexit;
	shopt -s nullglob;

	rm -fR /tmp/steward;
	mkdir -p /tmp/steward;

	# Expose architecture & distro info
	ARCH="$(dpkg --print-architecture)";
	DEBIAN_FRONTEND=noninteractive
	STEWARDFILE="${BASH_SOURCE[0]}";
	STEWARDFILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)";

	# shellcheck source=/dev/null
	source /etc/os-release;
	export ARCH DEBIAN_FRONTEND STEWARDFILE STEWARDFILE_DIR;
}

# @name include
# @type keyword
# @desc Include another Stewardfile (supports local files, URLs, and GitHub shorthand)
#
# @usage include <file|url>
#
# @arg <file|url>	Local path, URL
function steward:include() {
	local ARGS=("$@");
	local url="" file=; args:arg url '^https?://' || args:arg file;

	if [[ -n "$url" ]]; then
		file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		curl -1fsSL "$url" > "$file";
	fi

	# shellcheck source=/dev/null
	source "$file";
}

# @name key
# @type keyword
# @desc Add a GPG keyring for package verification
#
# @usage key <name> <url>
#
# @arg <name>	Keyring filename (without .gpg extension)
# @arg <url>	URL to the GPG key (ASCII-armored or binary)
function steward:key() {
	local ARGS=("$@");
	local name=; args:arg name || return;
	local url=;  args:arg url '^https?://' || return;

	steward:init-apt;

	cat <<-SH >> /tmp/steward/030-key-setup.sh
		curl -1fsSL '$url' > '/usr/share/keyrings/$name.gpg';
		if grep -qe '^-----BEGIN PGP PUBLIC KEY BLOCK-----' '/usr/share/keyrings/$name.gpg'; then
			mv '/usr/share/keyrings/$name.gpg' '/usr/share/keyrings/$name.asc';
			gpg --dearmor < '/usr/share/keyrings/$name.asc' > '/usr/share/keyrings/$name.gpg';
			rm -f '/usr/share/keyrings/$name.asc';
		fi

		chown root:root '/usr/share/keyrings/$name.gpg';
		chmod u+rw,go+r '/usr/share/keyrings/$name.gpg';
	SH
}

# @name src
# @type keyword
# @desc Add an APT repository source list
#
# @usage src [--no-key] <name> <repo> [dist] [...comp]
# @usage src <url:*.deb>
#
# @flag [--no-key]	Skip keyring verification
# @arg <name>		Source list filename (without .list extension)
# @arg <repo>		APT repository URL (e.g. "https://example.com/repo/")
# @arg [dist]		Distribution codename (suite) (ex.: jammy, bookwork, $VERSION_CODENAME)
# @arg [...comp]	Component(s) (ex.: main, security, universe)
function steward:src() {
	local ARGS=("$@");

	local url=;    args:arg -o url '.deb$';
	if [[ -n "$url" ]]; then
		steward:init-apt;
		file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		cat <<-SH >> "/tmp/steward/040-src-setup.sh"
			curl -1fsSL '$url' > '/tmp/steward/$file';
			dpkg -i '/tmp/steward/$file';
		SH
		return;
	fi

	local no_key=; args:flag no-key "";
	local name=;   args:arg name || return;
	local repo=;   args:arg repo;
	local dist=;   args:arg -o dist;
	local comp="${ARGS[*]}";

	steward:init-apt;

	local signer=; [[ "$no_key" != "true" ]] && signer="[signed-by=/usr/share/keyrings/$name.gpg]";

	cat <<-SH >> /tmp/steward/040-src-setup.sh
		echo 'deb $signer $repo $dist $comp' > '/etc/apt/sources.list.d/$name.list';
		chown root:root '/etc/apt/sources.list.d/$name.list';
		chmod u+rw,go+r '/etc/apt/sources.list.d/$name.list';
	SH
}

# @name apt
# @type keyword
# @desc Schedule an APT package for installation
#
# @usage apt [--try] <name[=version]>
#
# @flag [--try]			Don't fail if package unavailable
# @arg <name[=version]>	Package name, optionally with =version suffix
function steward:apt() {
	local ARGS=("$@");
	local try=;  args:flag try "";
	local name=; args:arg name || return;
	local mod=;

	steward:init-apt;

	[[ "$try" == "true" ]] && mod="?";
	echo "$name" >> "/tmp/steward/packages$mod";
}

# @name deb
# @type keyword
# @desc Schedule a .deb package for installation
#
# @usage deb [--try] <url>
#
# @flag [--try]	Don't fail if package unavailable
#
# @arg <url>	URL to a .deb file
function steward:deb() {
	local ARGS=("$@");
	local try=;  args:flag try "";
	local url=;  args:arg url '^https?://' || return;
	local file="$url";
	local onFail=;

	steward:init-apt;

	[[ "$try" == "true" ]] && onFail="|| true";
	file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";

	cat <<-SH >> "/tmp/steward/060-deb-install.sh"
		curl -1fsSL '$url' > '/tmp/steward/$file.deb' $onFail;
		dpkg -i '/tmp/steward/$file.deb' $onFail;
	SH
}

# @name bin
# @type keyword
# @desc Download and install a binary to /usr/local/bin
#
# @usage bin <name> <url>
#
# @arg <name>	Binary filename in /usr/local/bin
# @arg <url>	URL to download the binary from
function steward:bin() {
	local ARGS=("$@");
	local name=; args:arg name || return;
	local url=;  args:arg url '^https?://' || return;

	cat <<-SH >> /tmp/steward/080-bin-install.sh
		curl -1fsSL '$url' > '/usr/local/bin/$name';
		chown root:root '/usr/local/bin/$name';
		chmod +x '/usr/local/bin/$name';
	SH
}

# @name ext
# @type keyword
# @desc Execute an external installer script from a URL
#
# @usage ext <url> [shell] [...args]
#
# @arg <url>		URL to the installer script
# @arg [shell]		Interpreter to use. Default: bash.
# @arg [...args]	Additional arguments passed to the script
function steward:ext() {
	local ARGS=("$@");
	local url=;   args:arg url '^https?://' || return;
	local shell=; args:arg -o shell;

	cat <<-SH >> /tmp/steward/070-ext-installer.sh
		curl -1fsSL '$url' | '$shell' $@;
	SH
}

# @name defer
# @type keyword
# @desc Defer shell commands to run after all packages are installed
#
# @usage defer [:ord] [name] <<<"command"
# @usage defer [:ord] [name] <<SH ... SH
#
# @arg [:ord]	Order of script execution. Default 100.
# @arg [name]	Label for debugging.
function steward:defer() {
	local ARGS=("$@");
	local ord="100"; args:arg -o ord '^:([0-9]{3})$';
	local name=;     args:arg -o name;

	cat <<-SH >> "/tmp/steward/$ord-deferred-$name.sh";
		echo '-------------------';
		echo '--- BEGIN $name';
		echo '-------------------';
		$(cat)
		echo '===================';
		echo '=== END $name';
		echo '===================';
	SH
}

# @name amd64
# @type keyword
# @desc Run a command only on amd64 architecture
#
# @usage amd64 <command> <args...>
#
# @arg <keyword>	The steward keyword to run (e.g. :deb, :apt)
# @arg [...args]	Arguments for the keyword
function steward:amd64() {
	if [[ "$ARCH" == "amd64" ]]; then
		eval "$(printf '%q ' "$@")";
	fi
}

# @name arm64
# @type keyword
# @desc Run a command only on arm64 architecture
#
# @usage arm64 <keyword> <args...>
#
# @arg <keyword>	The steward command to run (e.g. deb, apt)
# @arg [...args]	Arguments for the keyword
function steward:arm64() {
	if [[ "$ARCH" == "arm64" ]]; then
		eval "$(printf '%q ' "$@")";
	fi
}

# @type keyword
# @name apply
# @desc Execute all queued operations in order (auto-invoked unless steward is importd/sourced)
#
# @flag [-d|--dry-run]	Dry run -- read the Stewardfiles, check the syntax & parameters, display what commands would be executed.
function steward:apply() {
	local ARGS=("$@");
	local dry_run=; args:flag dry-run d;
	local source="source";

	# Run with sudo privileges (skip for dry-run)
	[[ "$EUID" -ne 0 && "$dry_run" != "true" ]] && exec sudo "$0" "$@";
	# @todo ^^ $0 only applies if not sourced

	# Scripts sourced in subshell:
	# - receive the current ENV variables
	# - share ENV vars between each other
	# - run under stricter constraints
	[[ "$dry_run" == "true" ]] && source="cat";

  # shellcheck source=/dev/null
  for script in /tmp/steward/[0-9][0-9][0-9]-*.sh; do
    $source "$script";
  done
}

# @name use
# @type internal-keyword
# @desc Assign a namespace (prefix) for steward keywords (used when sourcing steward as a library).
#
# @arg <ns>	Namespace (prefix) for Stewardfile keywords. Default "steward:".
function steward:use() {
	local ARGS=("$@");
	local ns="steward:"; args:arg ns;

	shopt -s expand_aliases;
	# shellcheck disable=SC2139
	while IFS= read -r keyword; do
		alias "$ns$keyword"="steward:$keyword";
	done <<<"$(grep -B1 "^# @type keyword" "${BASH_SOURCE[0]}" | grep -oP '(?<=^# @name )\S+')"
}

function steward:init-apt() {
	if [[ -f /tmp/steward/020-prereq.sh ]]; then
		return;
	fi

	# Install pre-requisites
	cat <<-SH >> /tmp/steward/020-prereq.sh
		# Docker environments may have cleaned up the package lists
		[[ -z "$(ls -A /var/lib/apt/lists >/dev/null 2>&1)" ]] && apt update -qq;

		if ! command -V curl >/dev/null 2>&1 || ! command -V gpg >/dev/null 2>&1; then
			apt install -qqy --no-install-recommends apt-transport-https curl gpg;
		fi
	SH

	# Update repo lists & install required + optional packages
	cat <<-SH > "/tmp/steward/050-apt-install.sh"
		command -v apt >/dev/null 2>&1 || (echo "apt is not installed" && exit 1);

		apt update -qq;
		sort -u '/tmp/steward/packages' | xargs -r apt install -qqy --no-install-recommends;
		sort -u '/tmp/steward/packages' | xargs -r apt install -qqy --no-install-recommends || true;
	SH

	# Docker containers need APT cleanup.
	[[ -f /.dockerenv ]] && cat <<-SH > "/tmp/steward/082-apt-cleanup.sh"
		apt autoremove -y --purge;
		apt clean;
		rm -fR /var/lib/apt/lists;
	SH

	# Allow *.deb packages to pull in additional dependencies
	cat <<-SH > "/tmp/steward/081-deb-cleanup.sh"
		apt --fix-broken install -qqy;
		rm -fR /tmp/steward/*.deb;
	SH
}

function steward:help() {
	local self="${BASH_SOURCE[0]}";
	DOCFILE="$self"; export DOCFILE;

	help:header steward;

	echo "SYNTAX";
	help:section keyword;

	cat <<-TXT
	SCHEDULE
		$(# shellcheck disable=SC2034
		echo "	The order in which the scheduled actions ar executed.")

		$(grep -oP "(?<=/tmp/steward/)([-\w]+)(?=.sh)" "$self" | sort -u	| sed 's/^/	:/; s/-/\t/')

	TXT
}

source "$(dirname "${BASH_SOURCE[0]}")/libs/args"; # !inline: args:*
source "$(dirname "${BASH_SOURCE[0]}")/libs/help"; # !inline: help:*

steward:main "$@";
