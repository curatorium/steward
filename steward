# @name steward
# @type command
# @desc Declarative DSL for installing packages, in a shareable file format called Stewardfile.
#
# @usage steward [-t|--task <task>] [...file|url] < Stewardfile
# @usage cat Stewardfile | steward [-t|--task <task>] [...file|url]
#
# @opt  [-n|--namespace] -- Namespace (keyword prefix).
# @opt  [-t|--task] -- Run only the specified task (function name) from the Stewardfile.
# @flag [-f|--force] -- Force -- skip all guard checks (treat every guard as passed).
# @flag [-d|--dry-run] -- Dry run -- read the Stewardfiles, check the syntax & parameters, display what commands would be executed.
# @opt  [-x|--trace <lvl: app|all>] -- Level of trace tracing, "app" traces only calls from this file, "all" also traces dependencies. Default none.
# @flag [-h|--help] -- Prints out the usage guide.
#
# @arg [...file|url] -- Paths or URLs to process, default: Stewardfile
function steward:main() {
	local ARGS=("$@");

	local help=;       args:flag help h;
	[[ "$help" == "true" ]] && steward:help && return;

	local trace=;      args:opt  trace x;
	# shellcheck disable=SC2064
	[[ -n "$trace" ]] && "trace:$trace" && trap "trace:stop" EXIT;

	local namespace=;  args:opt  namespace n;
	local task=;       args:opt  task t;
	local force=;      args:flag force f; # dynamic scope: read by steward:guard()
	local dry_run=;    args:flag dry-run d;

	steward::init;

	# When sourced (not executed directly), stop here — only export functions, don't run the pipeline.
	[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return;


	# Detect stdin: drain redirects and pipes to a temp file; timeout prevents hanging on Docker's writerless FIFO.
	stat -L -c '%F' /dev/stdin 2>/dev/null | grep -qE 'regular file|fifo' &&
		timeout 0.2 cat > /tmp/steward/stdin 2>/dev/null &&
		[[ -s /tmp/steward/stdin ]] &&
		ARGS+=("/tmp/steward/stdin");

	# Default file to read is Stewardfile (or .dist fallback)
	[[ ${#ARGS[@]} -eq 0 && -f Stewardfile ]]      && ARGS+=(Stewardfile);
	[[ ${#ARGS[@]} -eq 0 && -f Stewardfile.dist ]]  && ARGS+=(Stewardfile.dist);

	# Outer subshell: isolates aliases and function definitions so they don't leak into the caller's scope.
	(
		# DSL syntactic sugar for Stewardfiles
		namespace:use "steward:[^:]*" as "$namespace";
		# Allows `task` to be used instead of function `task foo() { ... }`
		alias task='function';

		local before; before=$(declare -F | awk '{print $3}' | sort);
		for file in "${ARGS[@]}"; do
			# Per-file subshell: isolates each Stewardfile's tasks
			(
				steward:include "$file";

				# Identify functions defined by the Stewardfile
				funcs="$(comm -13 <(printf "%s\n" "$before") <(declare -F | awk '{print $3}' | sort))";
				for func in $funcs; do
				  [[ -n "$task" && "$func" != "$task" ]] && continue;
				  # Per-task subshell: guard's `exit 0` terminates only this subshell, not the whole pipeline
				  ("$func");
				done
			)
		done
	);

	steward:apply "$@";
}

function steward::init() {
	strict:on;

	rm -fR /tmp/steward;
	mkdir -p /tmp/steward;

	# Expose architecture & distro info
	ARCH="$(dpkg --print-architecture)";
	DEBIAN_FRONTEND=noninteractive;
	STEWARDFILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)";
	STEWARDFILE="$STEWARDFILE_DIR/$(basename "${BASH_SOURCE[0]}")";

	# shellcheck source=/dev/null
	source /etc/os-release;
	export ARCH DEBIAN_FRONTEND STEWARDFILE STEWARDFILE_DIR;
}

# @name include
# @type keyword
# @desc Include another Stewardfile (supports local files, URLs, and GitHub shorthand)
#
# @usage include <file|url>
#
# @arg <file|url> -- Local path, URL
function steward:include() {
	local ARGS=("$@");
	local url="" file=; args:arg url '^https?://' || args:arg file;

	if [[ -n "$url" ]]; then
		file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		file="/var/cache/steward/$file";
		curl -1fsSLR -z "$file" -o "$file" "$url";
	fi

	# shellcheck source=/dev/null
	source "$file";
}

# @name guard
# @type keyword
#
# @desc Conditionally skip task if command/file/directory exists.
#
# @usage guard <command>
# @usage guard --file <file>
# @usage guard --dir <dir>
#
# @flag [-f|--file] -- Check for file existence instead of command
# @flag [-d|--dir] -- Check for directory existence instead of command
# @arg <name> -- Command name, file path, or directory path to check
function steward:guard() {
	[[ "${force:-}" == "true" ]] && return 0; # dynamic scope: set in steward:main()

	local ARGS=("$@");
	local file=; args:flag file f;
	local dir=;  args:flag dir d;
	local name=; args:arg name;

	# exit (not return): each task runs in its own subshell, exit 0 skips the rest of the task
	if [[ "$file" == "true" ]]; then
		[[ -f "$name" ]] && exit 0;
	elif [[ "$dir" == "true" ]]; then
		[[ -d "$name" ]] && exit 0;
	else
		type -P "$name" >/dev/null 2>&1 && exit 0;
	fi
	return 0;
}

#
# Keyword collectors and their apply functions — colocated pairs
#

# @name key
# @type keyword
# @desc Add a GPG keyring for package verification
#
# @usage key <name> <url>
#
# @arg <name> -- Keyring filename (without .gpg extension)
# @arg <url> -- URL to the GPG key (ASCII-armored or binary)
function steward:key() {
	local ARGS=("$@");
	local name=; args:arg name || return;
	local url=;  args:arg url '^https?://' || return;

	echo "$name	$url" >> /tmp/steward/key.lst;
}

function steward::apply:key() {
	[[ -f /tmp/steward/key.lst ]] || return 0;

	while IFS=$'\t' read -r name url; do
		curl -1fsSLR -z "/var/cache/steward/$name.asc" -o "/var/cache/steward/$name.asc" "$url";
		if grep -qe '^-----BEGIN PGP PUBLIC KEY BLOCK-----' "/var/cache/steward/$name.asc"; then
			gpg --dearmor < "/var/cache/steward/$name.asc" > "/usr/share/keyrings/$name.gpg";
		else
			cp "/var/cache/steward/$name.asc" "/usr/share/keyrings/$name.gpg";
		fi

		chown root:root "/usr/share/keyrings/$name.gpg";
		chmod u+rw,go+r "/usr/share/keyrings/$name.gpg";
	done < /tmp/steward/key.lst;
}

# @name src
# @type keyword
# @desc Add an APT repository source list
#
# @usage src [--no-key] <name> <repo> [dist] [...comp]
# @usage src <url:*.deb>
#
# @flag [--no-key] -- Skip keyring verification
# @arg <name> -- Source list filename (without .list extension)
# @arg <repo> -- APT repository URL (e.g. "https://example.com/repo/")
# @arg [dist] -- Distribution codename (suite) (ex.: jammy, bookwork, $VERSION_CODENAME)
# @arg [...comp] -- Component(s) (ex.: main, security, universe)
function steward:src() {
	local ARGS=("$@");

	local url=;    args:arg -o url '.deb$';
	[[ -n "$url" ]] &&  echo "$url" >> /tmp/steward/src.lst && return;

	local no_key=; args:flag no-key "";
	local name=;   args:arg name || return;
	local repo=;   args:arg repo;
	local dist=;   args:arg -o dist;
	local comp="${ARGS[*]}";

	local signer=; [[ "$no_key" != "true" ]] && signer="[signed-by=/usr/share/keyrings/$name.gpg]";

	echo "$repo	$name	$signer	$dist	$comp" >> /tmp/steward/src.lst;
}

function steward::apply:src() {
	[[ -f /tmp/steward/src.lst ]] || return 0;

	while IFS=$'\t' read -r url name signer dist comp; do
		if [[ "$url" == *.deb ]]; then
			local file; file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
			curl -1fsSLR -z "/var/cache/steward/$file" -o "/var/cache/steward/$file" "$url";

			apt install -qqy --no-install-recommends "/var/cache/steward/$file";
		else
			echo "deb $signer $url $dist $comp" > "/etc/apt/sources.list.d/$name.list";

			chown root:root "/etc/apt/sources.list.d/$name.list";
			chmod u+rw,go+r "/etc/apt/sources.list.d/$name.list";
		fi
	done < /tmp/steward/src.lst;
}

# @name apt
# @type keyword
# @desc Schedule an APT package for installation
#
# @usage apt [--try|--temp] <name[=version]>
#
# @flag [--try] -- Don't fail if package unavailable
# @flag [--temp] -- Temporary package, removed after all installers finish (build deps)
# @arg <name[=version]> -- Package name, optionally with =version suffix
function steward:apt() {
	local ARGS=("$@");
	local try=;  args:flag try "";
	local temp=; args:flag temp "";
	local name=; args:arg name || return;

	if [[ "$try" == "true" ]]; then
		echo "$name" >> /tmp/steward/apt-try.pkgs;
	else
		echo "$name" >> /tmp/steward/apt.pkgs;
	fi
	if [[ "$temp" == "true" ]]; then
		echo "$name" >> /tmp/steward/apt-rem.pkgs;
	fi
}

function steward::apply:apt() {
	[[ -f /tmp/steward/apt.pkgs ]] || [[ -f /tmp/steward/apt-try.pkgs ]] || return 0;

	apt update -qq;

	if [[ -f /tmp/steward/apt.pkgs ]]; then
		xargs -r apt install -qqy --no-install-recommends < /tmp/steward/apt.pkgs;
	fi
	if [[ -f /tmp/steward/apt-try.pkgs ]]; then
		xargs -r apt install -qqy --no-install-recommends < /tmp/steward/apt-try.pkgs || true;
	fi
}

# @name deb
# @type keyword
# @desc Schedule a .deb package for installation
#
# @usage deb [--try|--temp] <url>
#
# @flag [--try] -- Don't fail if package unavailable
# @flag [--temp] -- Temporary package, removed after all installers finish (build deps)
#
# @arg <url> -- URL to a .deb file
function steward:deb() {
	local ARGS=("$@");
	local try=;  args:flag try "";
	local temp=; args:flag temp "";
	local url=;  args:arg url '^https?://' || return;
	local file; file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";

	echo "$url	$file	$try" >> /tmp/steward/deb.pkgs;

	if [[ "$try" == "true" ]]; then
		echo "/var/cache/apt/archives/$file" >> /tmp/steward/apt-try.pkgs;
	else
		echo "/var/cache/apt/archives/$file" >> /tmp/steward/apt.pkgs;
	fi

	if [[ "$temp" == "true" ]]; then
		echo "/var/cache/apt/archives/$file" >> /tmp/steward/apt-rem.pkgs;
	fi
}

function steward::apply:deb() {
	[[ -f /tmp/steward/deb.pkgs ]] || return 0;

	while IFS=$'\t' read -r url file try; do
		if [[ "$try" == "true" ]]; then
			curl -1fsSLR -z "/var/cache/apt/archives/$file" -o "/var/cache/apt/archives/$file" "$url" || true;
		else
			curl -1fsSLR -z "/var/cache/apt/archives/$file" -o "/var/cache/apt/archives/$file" "$url";
		fi

		# Resolve .deb path to package name in removal manifest
		if [[ -f /tmp/steward/apt-rem.pkgs ]]; then
			local pkg; pkg=$(dpkg-deb --field "/var/cache/apt/archives/$file" Package 2>/dev/null);
			[[ -n "$pkg" ]] && sed -i "s|^/var/cache/apt/archives/$file$|$pkg|" /tmp/steward/apt-rem.pkgs;
		fi
	done < /tmp/steward/deb.pkgs;
}

# @name bin
# @type keyword
# @desc Download and install a binary to /usr/local/bin
#
# @usage bin <name> <url>
#
# @arg <name> -- Binary filename in /usr/local/bin
# @arg <url> -- URL to download the binary from
function steward:bin() {
	local ARGS=("$@");
	local name=; args:arg name || return;
	local url=;  args:arg url '^https?://' || return;

	echo "$name	$url" >> /tmp/steward/bin.pkgs;
}

function steward::apply:bin() {
	[[ -f /tmp/steward/bin.pkgs ]] || return 0;

	while IFS=$'\t' read -r name url; do
		curl -1fsSLR -z "/var/cache/steward/$name" -o "/var/cache/steward/$name" "$url";
		cp "/var/cache/steward/$name" "/usr/local/bin/$name";

		chown root:root "/usr/local/bin/$name";
		chmod +x "/usr/local/bin/$name";
	done < /tmp/steward/bin.pkgs;
}

# @name tar
# @type keyword
# @desc Download a tar, extract it, and install a binary from it to /usr/local/bin
#
# @usage tar [--keep] <name> <path/to/bin> <url>
#
# @flag [--keep] -- Keep the extracted archive in /opt/<name>
# @arg <name> -- Binary filename in /usr/local/bin (and /opt/<name> if --keep)
# @arg <path> -- Path to the binary inside the archive
# @arg <url> -- URL to download the tar from
function steward:tar() {
	local ARGS=("$@");
	local keep=; args:flag keep "";
	local name=; args:arg name || return;
	local path=; args:arg path || return;
	local url=;  args:arg url '^https?://' || return;

	echo "$name	$path	$url	$keep" >> /tmp/steward/tar.pkgs;
}

function steward::apply:tar() {
	[[ -f /tmp/steward/tar.pkgs ]] || return 0;

	while IFS=$'\t' read -r name path url keep; do
		local file; file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		curl -1fsSLR -z "/var/cache/steward/$file" -o "/var/cache/steward/$file" "$url";

		local dir; [[ "$keep" == "true" ]] && dir="/opt/$name" || dir="$(mktemp -d)";
		mkdir -p "$dir";

		tar xzf "/var/cache/steward/$file" -C "$dir";
		cp "$dir/$path" "/usr/local/bin/$name";

		chown root:root "/usr/local/bin/$name";
		chmod +x "/usr/local/bin/$name";

		[[ "$keep" != "true" ]] && rm -fR "$dir";
	done < /tmp/steward/tar.pkgs;
}

# @name zip
# @type keyword
# @desc Download a zip archive, extract it, and install a binary from it to /usr/local/bin
#
# @usage zip [--keep] <name> <path/to/bin> <url>
#
# @flag [--keep] -- Keep the extracted archive in /opt/<name>
# @arg <name> -- Binary filename in /usr/local/bin (and /opt/<name> if --keep)
# @arg <path> -- Path to the binary inside the archive
# @arg <url> -- URL to download the zip archive from
function steward:zip() {
	local ARGS=("$@");
	local keep=; args:flag keep "";
	local name=; args:arg name || return;
	local path=; args:arg path || return;
	local url=;  args:arg url '^https?://' || return;

	echo "$name	$path	$url	$keep" >> /tmp/steward/zip.pkgs;
}

function steward::prereq:zip() {
	[[ -f /tmp/steward/zip.pkgs ]] || return 0;
	type -P unzip >/dev/null 2>&1 && return 0;
	steward:apt --temp unzip;
}

function steward::apply:zip() {
	[[ -f /tmp/steward/zip.pkgs ]] || return 0;

	while IFS=$'\t' read -r name path url keep; do
		local file; file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		curl -1fsSLR -z "/var/cache/steward/$file" -o "/var/cache/steward/$file" "$url";

		local dir; [[ "$keep" == "true" ]] && dir="/opt/$name" || dir="$(mktemp -d)";
		mkdir -p "$dir";

		unzip -qo "/var/cache/steward/$file" -d "$dir";
		cp "$dir/$path" "/usr/local/bin/$name";

		chown root:root "/usr/local/bin/$name";
		chmod +x "/usr/local/bin/$name";

		[[ "$keep" != "true" ]] && rm -fR "$dir";
	done < /tmp/steward/zip.pkgs;
}

# @name ext
# @type keyword
# @desc Execute an external installer script from a URL
#
# @usage ext <url> [shell] [...args]
#
# @arg <url> -- URL to the installer script
# @arg [shell] -- Interpreter to use. Default: bash.
# @arg [...args] -- Additional arguments passed to the script
function steward:ext() {
	local ARGS=("$@");
	local url=;         args:arg url '^https?://' || return;
	local shell="bash"; args:arg -o shell;

	echo "$url	$shell	${ARGS[*]}" >> /tmp/steward/ext.pkgs;
}

function steward::apply:ext() {
	[[ -f /tmp/steward/ext.pkgs ]] || return 0;

	local file;
	while IFS=$'\t' read -r url shell args; do
		file="$(printf '%s' "$url" | sed -E 's#[^A-Za-z0-9._-]+#-#g')";
		curl -1fsSLR -z "/var/cache/steward/$file" -o "/var/cache/steward/$file" "$url";

		# shellcheck disable=SC2086
		"$shell" $args < "/var/cache/steward/$file";
	done < /tmp/steward/ext.pkgs;
}

# @name npm
# @type keyword
# @desc Install npm packages (global by default, local with --dir)
#
# @usage npm <name[@version]>
# @usage npm --dir <path> [name[@version]]
#
# @opt  [--dir <path>] -- Project directory. Without name: `npm install`. With name: `npm install <name>`.
# @arg  [name[@version]] -- Package name, optionally with @version suffix. Without --dir: global install.
function steward:npm() {
	local ARGS=("$@");
	local dir=; args:opt dir "";
	local name=; args:arg -o name;

	[[ -z "$dir" && -z "$name" ]] && return 1;

	local key="${dir:-!global}";
	grep -q "^${key}	" /tmp/steward/npm.pkgs 2>/dev/null \
		&& sed -i "s|^${key}	.*|& ${name}|" /tmp/steward/npm.pkgs \
		|| echo "${key}	${name}" >> /tmp/steward/npm.pkgs;
}

function steward::prereq:npm() {
	[[ -f /tmp/steward/npm.pkgs ]] || return 0;
	type -P npm >/dev/null 2>&1 && return 0;
	if [[ -n "${NODEVS:-}" ]]; then
		steward:key nodesource https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key;
		steward:src nodesource "https://deb.nodesource.com/node_${NODEVS}.x" nodistro main;
	fi
	steward:apt nodejs;
}

function steward::apply:npm() {
	[[ -f /tmp/steward/npm.pkgs ]] || return 0;

	while IFS=$'\t' read -r dir pkgs; do
		# shellcheck disable=SC2086
		[[ "$dir" == "!global" ]] && npm install --global $pkgs && continue;
		[[ -z "$pkgs" ]]          && (cd "$dir" && npm install) && continue;
		# shellcheck disable=SC2086
		(cd "$dir" && npm install $pkgs);
	done < /tmp/steward/npm.pkgs;
}

# @name composer
# @type keyword
# @desc Install composer packages (global by default, local with --dir)
#
# @usage composer <name[@version]>
# @usage composer --dir <path> [name[@version]]
#
# @opt  [--dir <path>] -- Project directory. Without name: `composer install`. With name: `composer require <name>`.
# @arg  [name[@version]] -- Package name, optionally with @version constraint. Without --dir: global require.
function steward:composer() {
	local ARGS=("$@");
	local dir=; args:opt dir "";
	local name=; args:arg -o name;

	[[ -z "$dir" && -z "$name" ]] && return 1;

	local key="${dir:-!global}";
	grep -q "^${key}	" /tmp/steward/composer.pkgs 2>/dev/null    &&
		sed -i "s|^${key}	.*|& ${name}|" /tmp/steward/composer.pkgs ||
		echo "${key}	${name}" >> /tmp/steward/composer.pkgs;
}

function steward::prereq:composer() {
	[[ -f /tmp/steward/composer.pkgs ]] || return 0;
	type -P php >/dev/null 2>&1 && return 0;
	if [[ "${ID:-}" == "debian" ]]; then
		steward:key php https://packages.sury.org/php/apt.gpg;
		steward:src php "https://packages.sury.org/php/" "$VERSION_CODENAME" main;
	fi
	if [[ "${ID:-}" == "ubuntu" ]]; then
		steward:key php "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0xB8DC7E53946656EFBCE4C1DD71DAEAAB4AD4CAB6";
		steward:src php "https://ppa.launchpadcontent.net/ondrej/php/ubuntu" "$VERSION_CODENAME" main;
	fi
	steward:apt "php${PHPVS:-}-cli";
	steward:ext https://getcomposer.org/installer php -- --2 --install-dir=/usr/local/bin --filename=composer;
}

function steward::apply:composer() {
	[[ -f /tmp/steward/composer.pkgs ]] || return 0;

	while IFS=$'\t' read -r dir pkgs; do
		pkgs="${pkgs//@/:}";
		# shellcheck disable=SC2086
		[[ "$dir" == "!global" ]] && composer global require $pkgs && continue;
		[[ -z "$pkgs" ]]          && (cd "$dir" && composer install) && continue;
		# shellcheck disable=SC2086
		(cd "$dir" && composer require $pkgs);
	done < /tmp/steward/composer.pkgs;
}

# @name helm
# @type keyword
# @desc Install a Helm chart via `helm upgrade --install --atomic --wair --create-namespace --namespace ... --timeout ...` with safe defaults.
#
# @usage helm <namespace>/<release> <chart[@version]> [repo] [--timeout <seconds>] [<<<yaml]
#
# @arg  <namespace>/<release> -- Namespace and release name separated by / (creates namespace if missing)
# @arg  <chart[@version]> -- Chart reference (e.g. bitnami/nginx@1.2.3). Version pinned via --version.
# @arg  [repo] -- Repository URL to add (chart prefix used as repo name, deduplicated across calls)
# @opt  [--timeout <seconds>] -- Helm timeout in seconds (default: 60). Applies to both --wait and --atomic.
function steward:helm() {
	local ARGS=("$@");
	local release=;  args:arg release '.+/.+' || return;
	local chart=;    args:arg chart || return;
	local repo=;     args:arg -o repo '^https?://';
	local timeout=;  args:opt timeout "";

	# Extract namespace from release (namespace/release -> --namespace namespace)
	local namespace="${release%%/*}";
	release="${release##*/}";

	# Extract version from chart (chart@version -> --version version)
	local version=; [[ "$chart" == *@* ]] && version="${chart##*@}" && chart="${chart%%@*}";

	[[ -n "$repo" ]] && echo "${chart%%/*}	$repo" >> /tmp/steward/helm.lst;

	# Accept YAML values from stdin if provided
	local values=;
	if read -t 0; then
		cat > "/tmp/steward/helm.${release}.yml" 2>/dev/null;
		if [[ -s "/tmp/steward/helm.${release}.yml" ]]; then
			values="/tmp/steward/helm.${release}.yml";
		else
			rm -f "/tmp/steward/helm.${release}.yml";
		fi
	fi

	echo "$release	$chart	$namespace	$version	${timeout:-60}	$values" >> /tmp/steward/helm.pkgs;
}

function steward::prereq:helm() {
	[[ -f /tmp/steward/helm.pkgs ]] || return 0;
	type -P helm >/dev/null 2>&1 && return 0;
	steward:key helm https://packages.buildkite.com/helm-linux/helm-debian/gpgkey;
	steward:src helm https://packages.buildkite.com/helm-linux/helm-debian/any/ any main;
	steward:apt helm;
}

function steward::apply:helm() {
	[[ -f /tmp/steward/helm.pkgs ]] || return 0;

	# Add repos
	if [[ -f /tmp/steward/helm.lst ]]; then
		while IFS=$'\t' read -r name url; do
			helm repo add "$name" "$url";
		done < /tmp/steward/helm.lst;
		helm repo update;
	fi

	# Install releases in parallel
	while IFS=$'\t' read -r release chart namespace version timeout values; do
		local -a args=(
			--install "$release" "$chart"
			--atomic --wait --timeout "${timeout}s"
		);
		args+=(--namespace "$namespace" --create-namespace);
		[[ -n "$version" ]] && args+=(--version "$version");
		[[ -n "$values" && -f "$values" ]] && args+=(--values "$values");

		{ helm upgrade "${args[@]}" > "/tmp/steward/helm.${release}.log" 2>&1 ||
			echo "$release" >> /tmp/steward/helm.log; } &
	done < /tmp/steward/helm.pkgs;

	wait; # Awaits for all of the parallel helm charts to be installed

	for log in /tmp/steward/helm.*.log; do
		[[ -f "$log" ]] && cat "$log";
	done

	[[ -f /tmp/steward/helm.log ]] && echo "helm: failed releases: $(paste -sd, /tmp/steward/helm.log)" >&2 && return 1;
}

# @name pip
# @type keyword
# @desc Install pip packages (global by default, local venv with --dir)
#
# @usage pip <name[@version]>
# @usage pip --dir <path> [name[@version]]
#
# @opt  [--dir <path>] -- Project directory. Without name: venv + `pip install -r requirements.txt`. With name: venv + `pip install <name>`.
# @arg  [name[@version]] -- Package name, optionally with @version constraint. Without --dir: global install.
function steward:pip() {
	local ARGS=("$@");
	local dir=; args:opt dir "";
	local name=; args:arg -o name;

	[[ -z "$dir" && -z "$name" ]] && return 1;

	local key="${dir:-!global}";
	grep -q "^${key}	" /tmp/steward/pip.pkgs 2>/dev/null \
		&& sed -i "s|^${key}	.*|& ${name}|" /tmp/steward/pip.pkgs \
		|| echo "${key}	${name}" >> /tmp/steward/pip.pkgs;
}

function steward::prereq:pip() {
	[[ -f /tmp/steward/pip.pkgs ]] || return 0;
	type -P pip3 >/dev/null 2>&1 && return 0;
	steward:apt --temp python3-pip;
	steward:apt --temp python3-venv;
}

function steward::apply:pip() {
	[[ -f /tmp/steward/pip.pkgs ]] || return 0;

	while IFS=$'\t' read -r dir pkgs; do
		pkgs="${pkgs//@/==}";
		# shellcheck disable=SC2086
		[[ "$dir" == "!global" ]] && pip3 install --break-system-packages $pkgs && continue;
		[[ -z "$pkgs" ]]          && (cd "$dir" && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt) && continue;
		# shellcheck disable=SC2086
		(cd "$dir" && python3 -m venv .venv && .venv/bin/pip install $pkgs);
	done < /tmp/steward/pip.pkgs;
}

# @name go
# @type keyword
# @desc Install Go packages (global by default, local with --dir)
#
# @usage go <name[@version]>
# @usage go --dir <path> [name[@version]]
#
# @opt  [--dir <path>] -- Project directory. Without name: `go mod download`. With name: `go get <name>`.
# @arg  [name[@version]] -- Module path, optionally with @version (default: @latest). Without --dir: global install.
function steward:go() {
	local ARGS=("$@");
	local dir=; args:opt dir "";
	local name=; args:arg -o name;

	[[ -z "$dir" && -z "$name" ]] && return 1;

	[[ -n "$name" && "$name" != *@* ]] && name="${name}@latest";

	local key="${dir:-!global}";
	grep -q "^${key}	" /tmp/steward/go.pkgs 2>/dev/null \
		&& sed -i "s|^${key}	.*|& ${name}|" /tmp/steward/go.pkgs \
		|| echo "${key}	${name}" >> /tmp/steward/go.pkgs;
}

function steward::prereq:go() {
	[[ -f /tmp/steward/go.pkgs ]] || return 0;
	type -P go >/dev/null 2>&1 && return 0;
	steward:apt golang;
}

function steward::apply:go() {
	[[ -f /tmp/steward/go.pkgs ]] || return 0;

	while IFS=$'\t' read -r dir pkgs; do
		# shellcheck disable=SC2086
		[[ "$dir" == "!global" ]] && for pkg in $pkgs; do go install "$pkg"; done && continue;
		[[ -z "$pkgs" ]]          && (cd "$dir" && go mod download) && continue;
		# shellcheck disable=SC2086
		(cd "$dir" && go get $pkgs);
	done < /tmp/steward/go.pkgs;
}

# @name eager
# @type keyword
# @desc Run shell commands before the built-in pipeline
#
# @usage eager [:ord] [name] <<<"command"
# @usage eager [:ord] [name] <<SH ... SH
#
# @arg  [:ord] -- Order of script execution (00-99). Default 00.
# @arg  [name] -- Label.
function steward:eager() {
	local ARGS=("$@");
	local ord="00"; args:arg -o ord '^:([0-9]{2})$';
	local name=;    args:arg -o name '^[A-Za-z0-9_-]+$';

	ord=$(printf '%02d' $((10#$ord)));

	cat >> "/tmp/steward/eager-${ord}${name:+-$name}.sh";
}

function steward::apply:eager() {
	for script in /tmp/steward/eager-*.sh; do
		# shellcheck source=/dev/null
		source "$script" || { echo "ERROR: $script" >&2; exit 1; };
	done
}

# @name hook
# @type keyword
# @desc Run shell commands before/after built-in pipeline stages.
#
# @usage hook --before <stage> [:ord] [name] <<<"command"
# @usage hook --after <stage> [:ord] [name] <<<"command"
#
# @opt  [--before <stage>] -- Run just before the named pipeline stage.
# @opt  [--after <stage>] -- Run just after the named pipeline stage.
# @arg  [:ord] -- Order among hooks on the same stage (00-99). Default 00.
# @arg  [name] -- Label.
function steward:hook() {
	local ARGS=("$@");
	local before=; args:opt before "";
	local after=;  args:opt after "";
	local ord="00"; args:arg -o ord '^:([0-9]{2})$';
	local name=;    args:arg -o name '^[A-Za-z0-9_-]+$';

	local anchor="${before:-$after}";
	[[ -z "$anchor" ]] && echo "hook: --before or --after is required" >&2 && return 1;

	local dir; [[ -n "$before" ]] && dir="before" || dir="after";
	ord=$(printf '%02d' $((10#$ord)));

	cat >> "/tmp/steward/hook-${dir}-${anchor}-${ord}${name:+-$name}.sh";
}

function steward::apply:hook() {
	local dir;   dir="$1";   shift;
	local stage; stage="$1"; shift;

	for script in /tmp/steward/hook-"${dir}"-"${stage}"-*.sh; do
		# shellcheck source=/dev/null
		source "$script" || { echo "ERROR: $script" >&2; exit 1; };
	done
}

# @name defer
# @type keyword
# @desc Defer shell commands to run after all packages are installed
#
# @usage defer [:ord] [name] <<<"command"
# @usage defer [:ord] [name] <<SH ... SH
#
# @arg  [:ord] -- Order of script execution (00-99). Default 00.
# @arg  [name] -- Label.
function steward:defer() {
	local ARGS=("$@");
	local ord="00"; args:arg -o ord '^:([0-9]{2})$';
	local name=;    args:arg -o name '^[A-Za-z0-9_-]+$';

	ord=$(printf '%02d' $((10#$ord)));

	cat >> "/tmp/steward/defer-${ord}${name:+-$name}.sh";
}

function steward::apply:defer() {
	for script in /tmp/steward/defer-*.sh; do
		# shellcheck source=/dev/null
		source "$script" || { echo "ERROR: $script" >&2; exit 1; };
	done
}

# @name on-amd64
# @type keyword
# @desc Run a command only on amd64 architecture
#
# @usage on-amd64 <keyword> <args...>
#
# @arg <keyword> -- The steward keyword to run (e.g. deb, apt)
# @arg [...args] -- Arguments for the keyword
function steward:on-amd64() {
	if [[ "$ARCH" == "amd64" ]]; then
		# Direct "$@" won't work, it breaks quoting, can trigger globbing.
		# bashism printf %q shell-escapes each arg; eval re-parses them.
		eval "$(printf '%q ' "$@")";
	fi
}

# @name on-arm64
# @type keyword
# @desc Run a command only on arm64 architecture
#
# @usage on-arm64 <keyword> <args...>
#
# @arg <keyword> -- The steward keyword to run (e.g. deb, apt)
# @arg [...args] -- Arguments for the keyword
function steward:on-arm64() {
	if [[ "$ARCH" == "arm64" ]]; then
		eval "$(printf '%q ' "$@")";
	fi
}

# @name in-dev
# @type keyword
# @desc Run a command only in dev environment (APP_ENV=dev, APP_DEBUG=1, or DEBUG set)
#
# @usage in-dev <keyword> <args...>
#
# @arg <keyword> -- The steward keyword to run (e.g. deb, apt)
# @arg [...args] -- Arguments for the keyword
function steward:in-dev() {
	if [[ "${APP_ENV:-}" == "dev" || "${APP_DEBUG:-}" == "1" || -n "${DEBUG:-}" ]]; then
		eval "$(printf '%q ' "$@")";
	fi
}

#
# Standalone apply functions (no collector)
#

function steward::apply:prereqs() {
	mkdir -p /var/cache/steward;

	# Fresh Docker images or apt clean leave this directory missing or empty — force an update
	if [[ -z "$(find /var/lib/apt/lists -maxdepth 1 -name '*_Packages' -o -name '*_InRelease' 2>/dev/null)" ]]; then
		apt update -qq;
	fi

	if ! command -V curl >/dev/null 2>&1 || ! command -V gpg >/dev/null 2>&1; then
		apt install -qqy --no-install-recommends apt-transport-https ca-certificates curl gpg;
	fi
}

function steward::apply:clean-up() {
	grep -q buildkit /proc/1/mountinfo 2>/dev/null || return 0;

	if [[ -f /tmp/steward/apt-rem.pkgs ]]; then
		# Identify packages requested explicitly.
		sort -m -u /tmp/steward/apt.pkgs /tmp/steward/apt-try.pkgs -o /tmp/steward/apt-keep.pkgs 2>/dev/null;

		# Uninstall all temp packages (unless they were installed explicitly).
		comm -23 /tmp/steward/apt-rem.pkgs /tmp/steward/apt-keep.pkgs | xargs -r apt remove -qqy;
	fi

	apt autoremove -y --purge;

	findmnt /var/cache/apt/archives || apt clean;             # Only clean if it wasn't mounted (as a cache)
	findmnt /var/lib/apt/lists || rm -fR /var/lib/apt/lists;  # Only clean if it wasn't mounted (as a cache)
	findmnt /var/cache/steward || rm -fr /var/cache/steward;  # Only clean if it wasn't mounted (as a cache)
}

function steward::dry-run() {
	for file in /tmp/steward/*; do
		echo "=== ${file##*/} ===";
		cat "$file";
	done
}

#
# Orchestrator
#

# @type keyword
# @name apply
# @desc Execute all queued operations in order (auto-invoked unless steward is imported/sourced)
#
# @flag [-d|--dry-run] -- Dry run -- read the Stewardfiles, check the syntax & parameters, display what commands would be executed.
function steward:apply() {
	local ARGS=("$@");
	local dry_run=; args:flag dry-run d;

	# Run the rest in privileged mode
	[[ "$EUID" -ne 0 && "$dry_run" != "true" ]] && exec sudo "$0" "$@";
	# @todo ^^ $0 only applies if not sourced

	# If a keyword was used then we will install its prerequisites.
	steward::prereq:zip;
	steward::prereq:npm;
	steward::prereq:composer;
	steward::prereq:helm;
	steward::prereq:pip;
	steward::prereq:go;

	# Sort and deduplicate all manifest files (whitelist by extension)
	for file in /tmp/steward/*.lst /tmp/steward/*.pkgs; do
		sort -u "$file" -o "$file";
	done

	[[ "$dry_run" == "true" ]] && steward::dry-run && return;

	steward::apply:prereqs;

	steward::apply:eager;

	steward::apply:hook before key;       steward::apply:key;       steward::apply:hook after key;
	steward::apply:hook before src;       steward::apply:src;       steward::apply:hook after src;
	steward::apply:hook before deb;       steward::apply:deb;       steward::apply:hook after deb;
	steward::apply:hook before apt;       steward::apply:apt;       steward::apply:hook after apt;
	steward::apply:hook before ext;       steward::apply:ext;       steward::apply:hook after ext;
	steward::apply:hook before bin;       steward::apply:bin;       steward::apply:hook after bin;
	steward::apply:hook before tar;       steward::apply:tar;       steward::apply:hook after tar;
	steward::apply:hook before zip;       steward::apply:zip;       steward::apply:hook after zip;
	steward::apply:hook before npm;       steward::apply:npm;       steward::apply:hook after npm;
	steward::apply:hook before composer;  steward::apply:composer;  steward::apply:hook after composer;
	steward::apply:hook before helm;      steward::apply:helm;      steward::apply:hook after helm;
	steward::apply:hook before pip;       steward::apply:pip;       steward::apply:hook after pip;
	steward::apply:hook before go;        steward::apply:go;        steward::apply:hook after go;

	steward::apply:defer;

	steward::apply:clean-up;
}

